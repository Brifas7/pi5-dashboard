<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard</title>
<meta name="viewport" content="width=1920">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--accent-rgb:30,90,255;--accent:#1e5aff;--bg:#051c35;--text:#e0e8ff;--text-sub:#8ea4d4;--notif-bg:rgba(0,47,178,0.45);--overlay-bg:rgba(4,10,35,0.97);}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { width: 100vw; height: 100vh; overflow: hidden; font-family: 'Rajdhani', sans-serif; display: flex; flex-direction: column; background: none; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
.ops-avg-cell{background:rgba(var(--accent-rgb),0.08);border:1px solid rgba(var(--accent-rgb),0.2);border-radius:8px;padding:8px;text-align:center;}
.ops-avg-label{font-size:11px;color:var(--text-sub);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;}
.ops-avg-val{font-family:'Orbitron',monospace;font-size:15px;font-weight:700;color:var(--text);}
/* === GLASSMORPHISM === */
#nav-col button {
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
#nav-col button:hover {
  background: rgba(var(--accent-rgb), 0.28) !important;
  box-shadow: 0 0 24px rgba(var(--accent-rgb), 0.35);
  transform: translateY(-1px);
  transition: all 0.2s ease;
}
#timetext, #datetext {
  text-shadow: 0 0 15px color-mix(in srgb, var(--bezel-glow) 60%, transparent);
}

#clock-bezel {
  position: relative; display: inline-block; padding: 22px;
  background: radial-gradient(circle at center, rgba(255,255,255,0.08) 0%, transparent 65%);
  border: 24px solid rgba(20,20,30,0.95);
  border-radius: 50%;
  box-shadow: 0 0 60px color-mix(in srgb, var(--bezel-glow) 85%, transparent), 0 0 25px color-mix(in srgb, var(--bezel-glow) 40%, transparent), inset 0 0 80px rgba(0,0,0,0.9), inset 0 0 40px color-mix(in srgb, var(--bezel-glow) 30%, transparent), 0 20px 40px rgba(0,0,0,0.7);
  margin-bottom: 24px;
}
#clock { display: block; border-radius: 50%; }


</style>
</head>
<body>





<div style="position:relative;z-index:1;display:flex;flex-direction:column;width:100%;height:100%;">

  <div id="notif-bar" style="background:var(--notif-bg);border-bottom:1px solid rgba(var(--accent-rgb),0.4);padding:18px 28px;display:flex;gap:36px;align-items:center;font-size:16px;color:#a0b8e8;min-height:70px;">
    <span style="color:var(--text-sub);">Loading events...</span><span id="conn-status" style="margin-left:auto;font-size:12px;font-weight:700;letter-spacing:1px;color:#22c55e;">CONNECTED</span>
  </div>

  <div id="main-layout" style="display:flex;flex:1;padding:20px 28px;gap:28px;min-height:0;">

    <div id="nav-col" style="display:flex;flex-direction:column;gap:14px;width:319px;flex-shrink:0;">
      <button onclick="camOpen()" style="background:color-mix(in srgb, var(--nav-bg) 18%, transparent);border:1px solid color-mix(in srgb, var(--nav-bg) 40%, transparent);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">📷</span><span style="font-size:26px;font-weight:700;">Cameras</span>
      </button>
      <button onclick="lightOpen()" style="background:color-mix(in srgb, var(--nav-bg) 18%, transparent);border:1px solid color-mix(in srgb, var(--nav-bg) 40%, transparent);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">💡</span><span style="font-size:26px;font-weight:700;">Lighting</span>
      </button>
      <button onclick="opsOpen()" style="background:color-mix(in srgb, var(--nav-bg) 18%, transparent);border:1px solid color-mix(in srgb, var(--nav-bg) 40%, transparent);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">⚙️</span><span style="font-size:26px;font-weight:700;">Operations</span>
      </button>
      <button onclick="sensorsOpen()" style="background:color-mix(in srgb, var(--nav-bg) 18%, transparent);border:1px solid color-mix(in srgb, var(--nav-bg) 40%, transparent);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">🌡</span><span style="font-size:26px;font-weight:700;">Sensors</span>
      </button>
      <button onclick="settingsOpen()" style="background:color-mix(in srgb, var(--nav-bg) 18%, transparent);border:1px solid color-mix(in srgb, var(--nav-bg) 40%, transparent);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">🔧</span><span style="font-size:26px;font-weight:700;">Settings</span>
      </button>
    </div>

    <div id="clock-col" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:0;">
      <div id="clock-bezel"><canvas id="clock" width="660" height="660"></canvas></div>
      <div id="timetext" style="font-family:'Orbitron',monospace;font-size:58px;font-weight:700;color:var(--text);margin-top:18px;letter-spacing:5px;text-shadow:0 0 18px color-mix(in srgb, var(--bezel-glow) 60%, transparent);"></div>
      <div id="datetext" style="font-family:'Rajdhani',sans-serif;font-size:24px;color:var(--text-sub);margin-top:6px;letter-spacing:3px;font-weight:600;"></div>
    </div>

    <div id="right-col" style="display:flex;flex-direction:column;gap:14px;width:406px;flex-shrink:0;">
      <div style="background:color-mix(in srgb, var(--widget-bg) 14%, transparent);border:1px solid color-mix(in srgb, var(--widget-bg) 35%, transparent);border-radius:16px;padding:18px;">
        <div style="display:flex;flex-direction:column;align-items:center;padding:14px 8px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);margin-bottom:12px;">
          <div style="font-size:16px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Temperature</div>
          <div id="w-temp" style="font-family:'Orbitron',monospace;font-size:40px;color:var(--text);font-weight:700;">--</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);">
            <div style="font-size:14px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Humidity</div>
            <div id="w-humid" style="font-family:'Orbitron',monospace;font-size:26px;color:var(--text);font-weight:700;">--</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);">
            <div style="font-size:14px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Barometric</div>
            <div id="w-pres" style="font-family:'Orbitron',monospace;font-size:26px;color:var(--text);font-weight:700;">--</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);">
            <div style="font-size:14px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Air Quality</div>
            <div id="w-aqi" style="font-family:'Orbitron',monospace;font-size:26px;color:var(--text);font-weight:700;">--</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);">
            <div style="font-size:14px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Dew Point</div>
            <div id="w-dewpoint" style="font-family:'Orbitron',monospace;font-size:26px;color:var(--text);font-weight:700;">--</div>
          </div>
        </div>
        <div style="display:flex;align-items:center;justify-content:center;margin-top:14px;gap:8px;">
          <span id="moon-phase" style="font-size:17px;color:var(--text-sub);font-weight:600;">--</span>
        </div>
      </div>

      <div style="background:color-mix(in srgb, var(--widget-bg) 14%, transparent);border:1px solid color-mix(in srgb, var(--widget-bg) 35%, transparent);border-radius:16px;padding:18px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;" id="gauges"></div>
      </div>

      <div style="flex:1;"></div>

      <button onclick="autoOpen()" style="background:rgba(var(--accent-rgb),0.18);border:1px solid rgba(var(--accent-rgb),0.4);border-radius:16px;padding:26px 12px;color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:12px;width:100%;">
        <span style="font-size:28px;">⚡</span>
        <span style="font-family:'Rajdhani',sans-serif;font-size:22px;font-weight:700;letter-spacing:1px;">AUTOMATION</span>
      </button>
    </div>

  </div>
</div>

<script>
const _HOST=window.location.hostname;


function timeAgo(ts) {
  const diff = Math.floor(Date.now()/1000 - ts);
  if(diff < 60) return diff + 's ago';
  if(diff < 3600) return Math.floor(diff/60) + 'm ago';
  if(diff < 86400) return Math.floor(diff/3600) + 'h ago';
  return Math.floor(diff/86400) + 'd ago';
}





async function fetchEvents() {
  try {
    const res = await fetch('/api/notifications');
    const events = await res.json();
    const bar = document.getElementById('notif-bar');
    if(!events || events.length === 0) {
      bar.innerHTML = '<span style="color:var(--text-sub);">No recent events</span>';
      return;
    }
    bar.innerHTML = events.map(e => `
      <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
        <div style="width:12px;height:12px;border-radius:50%;background:var(--accent);animation:pulse 2s infinite;flex-shrink:0;"></div>
        <span><b style="color:var(--text)">${e.icon} ${e.source}</b> — ${e.message} — ${timeAgo(e.time)}</span>
      </div>
    `).join('');
  } catch(err) {
    console.log('Events fetch failed:', err);
  }
}

function buildGauges(data) {
  const gaugeData = [
    {label:'CPU', value:Math.round(data.cpu_percent)},
    {label:'Pi Temp', value:Math.round(data.cpu_temp_f), max:200, suffix:'°F'},
    {label:'RAM', value:Math.round(data.ram_percent)},
    {label:'Storage', value:Math.round(data.disk_percent)}
  ];
  const gaugesEl = document.getElementById('gauges');
  gaugesEl.innerHTML = '';
  const circ = 364.4;
  gaugeData.forEach(g => {
    const pct = g.max ? Math.min(g.value/g.max*100,100) : g.value;
    const dash = (pct/100)*circ;
    const suffix = g.suffix||'%';
    const gaugeColor = getComputedStyle(document.documentElement).getPropertyValue('--gauge').trim()||'#1e5aff';
    gaugesEl.innerHTML += `<div style="display:flex;flex-direction:column;align-items:center;gap:6px;"><div style="position:relative;width:145px;height:145px;"><svg width="145" height="145" viewBox="0 0 145 145"><circle cx="72" cy="72" r="58" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="8"/><circle cx="72" cy="72" r="58" fill="none" stroke="${gaugeColor}" stroke-width="8" stroke-dasharray="${dash} ${circ}" stroke-linecap="round" transform="rotate(-90 72 72)"/></svg><div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Orbitron',monospace;font-size:18px;color:var(--text);font-weight:700;">${g.value}${suffix}</div></div><div style="font-size:15px;color:var(--text-sub);font-weight:600;text-transform:uppercase;letter-spacing:1px;">${g.label}</div></div>`;
  });
}

async function fetchStats() {
  try {
    const res = await fetch('/api/system');
    const data = await res.json();
    var cs = document.getElementById('conn-status');
    if (cs) { cs.textContent = 'CONNECTED'; cs.style.color = '#22c55e'; }
    buildGauges(data);
  } catch(e) {
    console.log('Stats fetch failed:', e);
    var cs = document.getElementById('conn-status');
    if (cs) { cs.textContent = 'OFFLINE'; cs.style.color = '#ef4444'; }
  }
}

fetchEvents();
fetchStats();
setInterval(fetchEvents, 30000);
setInterval(fetchStats, 5000);
setInterval(fetchSolar, 3600000);

async function fetchSolar() {
  try {
    const r = await fetch('/api/solar');
    const d = await r.json();
    const el = document.getElementById('moon-phase');
    if (el) el.textContent = d.moon_icon + ' ' + d.moon_phase_name;
  } catch(e) {}
}
async function fetchSensors() {
  try {
    const r = await fetch('/api/sensors');
    const d = await r.json();
    if(d.sensors){
      d.sensors.forEach(s => {
        if(s.id==='rak_temp') document.getElementById('w-temp').textContent=s.last_value+'°F';
        if(s.id==='rak_humidity') document.getElementById('w-humid').textContent=s.last_value+'%';
        if(s.id==='rak_pressure') document.getElementById('w-pres').textContent=s.last_value+' hPa';
        if(s.id==='rak_airquality') document.getElementById('w-aqi').textContent=Math.round(s.last_value);
        if(s.id==='rak_dewpoint') document.getElementById('w-dewpoint').textContent=s.last_value+'°F';
      });
    }
  } catch(e) {}
}
fetchSensors();
setInterval(fetchSensors, 60000);
fetchSolar();

const canvas = document.getElementById('clock');
const ctx = canvas.getContext('2d');
const C = 660, R = C/2;

function _clockAccent(){
  if(typeof _themeColors!=='undefined'&&typeof _settings!=='undefined'){
    var c=_themeColors[_settings.activeTheme];
    if(c)return c.clock;
  }
  return '#1e5aff';
}
function _clockAccentDim(){
  if(typeof _themeColors!=='undefined'&&typeof _settings!=='undefined'){
    var c=_themeColors[_settings.activeTheme];
    if(c)return 'rgba('+c.rgb+',0.35)';
  }
  return 'rgba(30,90,255,0.35)';
}
function _clockText(){
  if(typeof _themeColors!=='undefined'&&typeof _settings!=='undefined'){
    var c=_themeColors[_settings.activeTheme];
    if(c)return c.text;
  }
  return '#e0e8ff';
}
function drawClock() {
  const now = new Date();
  const hrs = now.getHours(), mins = now.getMinutes(), secs = now.getSeconds();
  const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  ctx.clearRect(0,0,C,C);
  ctx.beginPath();
  ctx.arc(R,R,R-4,0,Math.PI*2);
  ctx.fillStyle='#0d0d0d';
  ctx.fill();
  for(let i=0;i<60;i++){
    const ang=(i*6-90)*Math.PI/180;
    const isMaj=i%5===0;
    const len=isMaj?28:14;
    const r1=R-22, r2=r1-len;
    ctx.beginPath();
    ctx.moveTo(R+r1*Math.cos(ang),R+r1*Math.sin(ang));
    ctx.lineTo(R+r2*Math.cos(ang),R+r2*Math.sin(ang));
    ctx.strokeStyle=isMaj?_clockAccent():_clockAccentDim();
    ctx.lineWidth=isMaj?4:2;
    ctx.stroke();
  }
  const nums=[
    {o:12,i:'00',a:0},{o:1,i:13,a:30},{o:2,i:14,a:60},{o:3,i:15,a:90},
    {o:4,i:16,a:120},{o:5,i:17,a:150},{o:6,i:18,a:180},{o:7,i:19,a:210},
    {o:8,i:20,a:240},{o:9,i:21,a:270},{o:10,i:22,a:300},{o:11,i:23,a:330}
  ];
  nums.forEach(n=>{
    const rad=(n.a-90)*Math.PI/180;
    ctx.font='bold 32px Orbitron';
    ctx.fillStyle=_clockText();
    ctx.textAlign='center';
    ctx.textBaseline='middle';
    ctx.fillText(n.o, R+242*Math.cos(rad), R+242*Math.sin(rad));
    ctx.font='400 18px Orbitron';
    ctx.fillStyle=_clockAccent();
    ctx.fillText(n.i, R+178*Math.cos(rad), R+178*Math.sin(rad));
  });
  const hourDeg=((hrs%12)*30+mins*0.5-90)*Math.PI/180;
  const minDeg=(mins*6+secs*0.1-90)*Math.PI/180;
  const secDeg=(secs*6-90)*Math.PI/180;
  ctx.lineCap='round';
  ctx.beginPath();
  ctx.moveTo(R,R);
  ctx.lineTo(R+162*Math.cos(hourDeg),R+162*Math.sin(hourDeg));
  ctx.strokeStyle=_clockAccent();
  ctx.lineWidth=10;
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(R,R);
  ctx.lineTo(R+220*Math.cos(minDeg),R+220*Math.sin(minDeg));
  ctx.strokeStyle=_clockAccent();
  ctx.lineWidth=6;
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(R,R);
  ctx.lineTo(R+248*Math.cos(secDeg),R+248*Math.sin(secDeg));
  ctx.strokeStyle='#ef4444';
  ctx.lineWidth=2.5;
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(R,R,14,0,Math.PI*2);
  ctx.fillStyle=_clockAccent();
  ctx.fill();
  const m=String(mins).padStart(2,'0');
  const s=String(secs).padStart(2,'0');
  var _tf = localStorage.getItem('dashTimeFormat') || '24';
  if (_tf === '12') {
    var _h12 = hrs % 12 || 12;
    var _ap = hrs >= 12 ? 'PM' : 'AM';
    document.getElementById('timetext').textContent = _h12 + ':' + m + ':' + s + ' ' + _ap;
  } else {
    var h24 = String(hrs).padStart(2,'0');
    document.getElementById('timetext').textContent = h24 + ':' + m + ':' + s;
  }
  const mo=now.getMonth()+1, d=now.getDate(), y=now.getFullYear();
  document.getElementById('datetext').textContent=`${days[now.getDay()]} · ${mo}/${d}/${y}`;
  requestAnimationFrame(drawClock);
}
drawClock();
</script>

<!-- ============================================================
     CAMERA SUBMENU
     ============================================================ -->
<style>
  #cam-overlay { font-family: 'Rajdhani', sans-serif; color: var(--text); }
  .cam-header { display:flex; align-items:center; justify-content:space-between; padding:16px 24px; flex-shrink:0; background:rgba(10,20,60,0.7); border-bottom:1px solid rgba(var(--accent-rgb),0.25); }
  .cam-title { font-size:20px; font-weight:700; letter-spacing:2px; color:var(--text); }
  .cam-btn { background:rgba(var(--accent-rgb),0.15); border:1px solid rgba(var(--accent-rgb),0.35); color:var(--text); border-radius:8px; padding:8px 18px; font-family:'Rajdhani',sans-serif; font-size:14px; font-weight:700; letter-spacing:1px; cursor:pointer; transition:background 0.2s; }
  .cam-btn:hover { background:rgba(var(--accent-rgb),0.3); }
  .cam-btn-close { background:rgba(220,40,40,0.12); border-color:rgba(220,40,40,0.35); color:#fca5a5; }
  .cam-btn-close:hover { background:rgba(220,40,40,0.28); }
  .cam-btn-danger { background:rgba(220,40,40,0.15); border-color:rgba(220,40,40,0.4); color:#fca5a5; }
  .cam-btn-danger:hover { background:rgba(220,40,40,0.3); }
  .cam-list-body { display:flex; flex:1; gap:20px; padding:20px; min-height:0; }
  .cam-feeds-col { flex:1; display:flex; flex-direction:column; gap:12px; min-height:0; }
  .cam-actions-col { width:200px; display:flex; flex-direction:column; gap:14px; padding-top:40px; }
  .cam-col-label { font-size:11px; font-weight:700; letter-spacing:2px; color:var(--text-sub); text-transform:uppercase; padding-left:4px; }
  .cam-feed-scroll { flex:1; overflow-y:auto; display:flex; flex-direction:column; gap:10px; }
  .cam-feed-item { display:flex; align-items:center; gap:14px; background:rgba(var(--accent-rgb),0.1); border:1px solid rgba(var(--accent-rgb),0.25); border-radius:10px; padding:14px 16px; cursor:pointer; transition:background 0.2s; user-select:none; }
  .cam-feed-item:hover { background:rgba(var(--accent-rgb),0.22); }
  .cam-feed-name { font-size:17px; font-weight:700; flex:1; }
  .cam-offline-label { font-size:11px; font-weight:700; letter-spacing:1px; color:#f87171; background:rgba(220,40,40,0.15); border:1px solid rgba(220,40,40,0.3); border-radius:4px; padding:2px 8px; }
  .cam-thumb { width:96px; height:54px; object-fit:cover; border-radius:6px; border:1px solid rgba(var(--accent-rgb),0.3); background:rgba(0,0,0,0.4); }
  .cam-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
  .cam-dot-on { background:#22c55e; box-shadow:0 0 6px rgba(34,197,94,0.7); animation:cam-pulse 2s infinite; }
  .cam-dot-off { background:#ef4444; }
  @keyframes cam-pulse { 0%,100% { box-shadow:0 0 4px rgba(34,197,94,0.5); } 50% { box-shadow:0 0 10px rgba(34,197,94,0.9); } }
  .cam-live-body { flex:1; display:flex; align-items:center; justify-content:center; position:relative; padding:16px; min-height:0; }
  .cam-live-badge { display:flex; align-items:center; gap:7px; background:rgba(220,40,40,0.2); border:1px solid rgba(220,40,40,0.4); border-radius:6px; padding:4px 12px; font-size:13px; font-weight:700; letter-spacing:2px; color:#fca5a5; }
  .cam-live-badge-dot { width:8px; height:8px; border-radius:50%; background:#ef4444; box-shadow:0 0 6px rgba(239,68,68,0.8); animation:cam-pulse 1.5s infinite; }
  .cam-arrow { position:absolute; top:50%; transform:translateY(-50%); background:rgba(var(--accent-rgb),0.2); border:1px solid rgba(var(--accent-rgb),0.4); color:var(--text); border-radius:8px; width:44px; height:80px; font-size:20px; cursor:pointer; transition:background 0.2s; display:flex; align-items:center; justify-content:center; }
  .cam-arrow:hover { background:rgba(var(--accent-rgb),0.4); }
  .cam-arrow-left { left:16px; }
  .cam-arrow-right { right:16px; }



  .cam-filter-bar { display:flex; gap:12px; padding:14px 20px; flex-shrink:0; border-bottom:1px solid rgba(var(--accent-rgb),0.15); }
  .cam-filter-select { background:rgba(var(--accent-rgb),0.12); border:1px solid rgba(var(--accent-rgb),0.3); color:var(--text); border-radius:8px; padding:8px 14px; font-family:'Rajdhani',sans-serif; font-size:15px; font-weight:600; cursor:pointer; }
  .cam-filter-select option { background:#0a1428; }
  .cam-clip-item { display:flex; align-items:center; gap:14px; padding:14px 0; border-bottom:1px solid rgba(var(--accent-rgb),0.12); cursor:pointer; transition:background 0.15s; border-radius:4px; }
  .cam-clip-item:hover { background:rgba(var(--accent-rgb),0.08); padding-left:8px; }
  .cam-clip-item.selected { background:rgba(var(--accent-rgb),0.18); padding-left:8px; }
  .cam-clip-thumb { width:112px; height:63px; object-fit:cover; border-radius:6px; border:1px solid rgba(var(--accent-rgb),0.25); background:#0a1428; flex-shrink:0; }
  .cam-clip-info { flex:1; display:flex; flex-direction:column; gap:4px; }
  .cam-clip-cam { font-size:16px; font-weight:700; color:var(--text); }
  .cam-clip-type { font-size:14px; color:#93c5fd; font-weight:600; }
  .cam-clip-meta { font-size:13px; color:var(--text-sub); }
  .cam-delete-btn { background:none; border:1px solid rgba(220,40,40,0.3); border-radius:6px; color:#f87171; font-size:18px; width:38px; height:38px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background 0.2s; flex-shrink:0; }
  .cam-delete-btn:hover { background:rgba(220,40,40,0.2); }
  .cam-check-circle { width:28px; height:28px; border-radius:50%; flex-shrink:0; border:2px solid rgba(var(--accent-rgb),0.5); background:transparent; display:flex; align-items:center; justify-content:center; font-size:16px; transition:all 0.15s; }
  .cam-check-circle.checked { background:#1e5aff; border-color:#1e5aff; color:#fff; }
  .cam-bulk-bar { display:flex; justify-content:space-between; align-items:center; padding:14px 20px; flex-shrink:0; background:rgba(var(--accent-rgb),0.08); border-top:1px solid rgba(var(--accent-rgb),0.2); }
  .cam-empty, .cam-loading { padding:40px; text-align:center; color:var(--text-sub); font-size:16px; font-weight:600; letter-spacing:1px; }
  .cam-screen { display:none; flex-direction:column; height:100%; }
  .cam-screen.active { display:flex; }
</style>

<div id="cam-overlay" style="display:none; position:fixed; inset:0; background:var(--overlay-bg); z-index:1000; flex-direction:column;">
  <div id="cam-screen-list" class="cam-screen">
    <div class="cam-header">
      <span class="cam-title">📷 CAMERAS</span>
      <button class="cam-btn cam-btn-close" onclick="camClose()">✕ CLOSE</button>
    </div>
    <div class="cam-list-body">
      <div class="cam-feeds-col">
        <div class="cam-col-label">LIVE FEEDS</div>
        <div id="cam-feed-scroll" class="cam-feed-scroll"></div>
        
      </div>
      <div class="cam-actions-col">
        <button class="cam-btn" onclick="camShowClips()">🎬  SAVED CLIPS</button>
        <button class="cam-btn" onclick="camShowSettings()">⚙  CAM SETTINGS</button>
      </div>
    </div>
  </div>
  <div id="cam-screen-live" class="cam-screen">
    <div class="cam-header">
      <div style="display:flex; align-items:center; gap:14px;">
        <span id="cam-live-title" class="cam-title"></span>
        <div class="cam-live-badge"><div class="cam-live-badge-dot"></div>LIVE</div>
      </div>
      <div style="display:flex; gap:10px;">
        
        <button class="cam-btn cam-btn-close" onclick="camBackToList()">✕ CLOSE</button>
      </div>
    </div>
    <div class="cam-live-body">
      <button class="cam-arrow cam-arrow-left" onclick="camCycle(-1)">◀</button>
      <div id="cam-live-container" style="width:calc(100% - 120px);height:100%;display:flex;align-items:center;justify-content:center;"></div>
      <button class="cam-arrow cam-arrow-right" onclick="camCycle(1)">▶</button>
    </div>
  </div>
  
  
  <div id="cam-screen-clips" class="cam-screen">
    <div class="cam-header">
      <span class="cam-title">🎬  SAVED CLIPS</span>
      <div style="display:flex; gap:10px;">
        <button class="cam-btn" id="cam-select-mode-btn" onclick="camToggleSelectMode()">SELECT MODE</button>
        <button class="cam-btn cam-btn-close" onclick="camBackToList()">✕ CLOSE</button>
      </div>
    </div>
    <div class="cam-filter-bar">
      <select id="cam-filter-camera" class="cam-filter-select" onchange="camApplyFilters()">
        <option value="all">All Cameras</option>
      </select>
      <select id="cam-filter-label" class="cam-filter-select" onchange="camApplyFilters()">
        <option value="all">All Types</option>
        <option value="person">Person</option>
        <option value="car">Vehicle</option>
        <option value="dog">Dog</option>
        <option value="cat">Cat</option>
      </select>
    </div>
    <div id="cam-clip-list" style="flex:1; overflow-y:auto; padding:0 20px 20px;"></div>
    <div id="cam-bulk-bar" class="cam-bulk-bar" style="display:none;">
      <button class="cam-btn" onclick="camSelectAll()">SELECT ALL</button>
      <button class="cam-btn cam-btn-danger" id="cam-bulk-delete-btn" onclick="camBulkDelete()">DELETE SELECTED (0)</button>
    </div>
  </div>
  <div id="cam-screen-playback" class="cam-screen">
    <div class="cam-header">
      <span id="cam-playback-title" class="cam-title"></span>
      <button class="cam-btn cam-btn-close" onclick="camBackToClips()">✕ CLOSE</button>
    </div>
    <div style="flex:1; display:flex; align-items:center; justify-content:center; padding:20px;">
      <video id="cam-playback-video" controls style="max-width:100%; max-height:100%; border-radius:8px; border:1px solid rgba(var(--accent-rgb),0.3); background:#000;"></video>
    </div>
  </div>
<div id="cam-screen-settings" class="cam-screen">
<div class="cam-header">
<span class="cam-title">&#9881; CAMERA SETTINGS</span>
<div style="display:flex;gap:10px;">
<button class="cam-btn" onclick="camBackToList()">&#9664; BACK</button>
<button class="cam-btn cam-btn-close" onclick="camClose()">&#10005; CLOSE</button>
</div>
</div>
<div style="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px;">

<div style="background:rgba(var(--accent-rgb),0.08);border:1px solid rgba(var(--accent-rgb),0.2);border-radius:12px;padding:18px 22px;display:flex;flex-direction:column;gap:12px;">
<div style="font-size:11px;font-weight:700;letter-spacing:2px;color:var(--text-sub);text-transform:uppercase;">CONFIGURED CAMERAS</div>
<div id="cam-settings-list" style="display:flex;flex-direction:column;gap:8px;"></div>
</div>

<div style="background:rgba(var(--accent-rgb),0.08);border:1px solid rgba(var(--accent-rgb),0.2);border-radius:12px;padding:18px 22px;display:flex;flex-direction:column;gap:12px;">
<div style="font-size:11px;font-weight:700;letter-spacing:2px;color:var(--text-sub);text-transform:uppercase;">RECORDING RETENTION</div>
<div style="display:flex;align-items:center;justify-content:space-between;padding:6px 0;">
<div><div style="font-size:16px;font-weight:700;">Continuous Recording</div><div style="font-size:13px;color:var(--text-sub);">Days to keep 24/7 footage</div></div>
<select class="cam-btn" id="cam-retain-continuous" style="padding:8px 14px;" onchange="camSaveRetention()">
<option value="3">3 days</option>
<option value="7" selected>7 days</option>
<option value="14">14 days</option>
<option value="30">30 days</option>
<option value="60">60 days</option>
</select>
</div>
<div style="display:flex;align-items:center;justify-content:space-between;padding:6px 0;">
<div><div style="font-size:16px;font-weight:700;">Detection Clips</div><div style="font-size:13px;color:var(--text-sub);">Days to keep motion/object clips</div></div>
<select class="cam-btn" id="cam-retain-clips" style="padding:8px 14px;" onchange="camSaveRetention()">
<option value="7">7 days</option>
<option value="14" selected>14 days</option>
<option value="30">30 days</option>
<option value="60">60 days</option>
<option value="90">90 days</option>
</select>
</div>
<div style="display:flex;align-items:center;justify-content:space-between;padding:6px 0;">
<div><div style="font-size:16px;font-weight:700;">Snapshots</div><div style="font-size:13px;color:var(--text-sub);">Days to keep snapshot images</div></div>
<select class="cam-btn" id="cam-retain-snapshots" style="padding:8px 14px;" onchange="camSaveRetention()">
<option value="3">3 days</option>
<option value="7" selected>7 days</option>
<option value="14">14 days</option>
<option value="30">30 days</option>
</select>
</div>
</div>

</div>
</div>
</div>

<script>
const _cam = {
  cameras: [], currentIdx: 0,
  clips: [], filteredClips: [], selectMode: false, selectedClips: new Set()
};
function _camFmt(name) { return name.replace(/[-_]/g, ' ').replace(/\b\w/g, c => c.toUpperCase()); }
function _camFmtTime(ts) {
  const d = new Date(ts * 1000), now = new Date();
  const diffDays = Math.floor((now - d) / 86400000);
  const t = d.toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
  if (diffDays === 0) return 'Today ' + t;
  if (diffDays === 1) return 'Yesterday ' + t;
  return d.toLocaleDateString() + ' ' + t;
}
function _camScreen(id) {
  document.querySelectorAll('.cam-screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById('cam-screen-' + id);
  if (el) el.classList.add('active');
}
function _camStopStreams() {
  var container = document.getElementById('cam-live-container');
  if (container) container.innerHTML = '';
  var vid = document.getElementById('cam-playback-video');
  if (vid) { vid.pause(); vid.src = ''; }
}
async function camOpen() {
  const overlay = document.getElementById('cam-overlay');
  overlay.style.display = 'flex';
  overlay.style.flexDirection = 'column';
  _camScreen('list');
  try {
    const r = await fetch('/api/camera/list');
    const data = await r.json();
    _cam.cameras = data.cameras || [];
  } catch(e) { _cam.cameras = []; }
  _camRenderList();
}
function camClose() { _camStopStreams(); if(_isMobile()) return _mobileClose(); document.getElementById('cam-overlay').style.display = 'none'; }
function _camRenderList() {
  const el = document.getElementById('cam-feed-scroll');
  if (!el) return;
  if (_cam.cameras.length === 0) { el.innerHTML = '<div class="cam-empty">No cameras registered in Frigate</div>'; return; }
  el.innerHTML = _cam.cameras.map((cam, i) => `
    <div class="cam-feed-item" onclick="camOpenLive(${i})">
      <div class="cam-dot ${cam.online ? 'cam-dot-on' : 'cam-dot-off'}"></div>
      <span class="cam-feed-name">${_camFmt(cam.name)}</span>
      ${!cam.online ? '<span class="cam-offline-label">OFFLINE</span>' : ''}
      <img class="cam-thumb" src="/api/camera/${cam.id}/snapshot?t=${Date.now()}" onerror="this.style.visibility='hidden'" alt="" />
    </div>
  `).join('');
}
function camOpenLive(idx) { _cam.currentIdx = idx; _camScreen('live'); _camLoadLive(); }

function camCycle(dir) {
  _camStopStreams();
  _cam.currentIdx = (_cam.currentIdx + dir + _cam.cameras.length) % _cam.cameras.length;
  _camLoadLive();
}
function camBackToList() { _camStopStreams(); _camScreen('list'); _camRenderList(); }
async function camShowClips() {
  _camScreen('clips');
  _cam.selectMode = false; _cam.selectedClips.clear();
  document.getElementById('cam-select-mode-btn').textContent = 'SELECT MODE';
  document.getElementById('cam-bulk-bar').style.display = 'none';
  document.getElementById('cam-clip-list').innerHTML = '<div class="cam-loading">Loading clips...</div>';
  try {
    var r = await fetch('/api/clips?limit=100');
    var data = await r.json();
    _cam.clips = data.clips || [];
    var camFilter = document.getElementById('cam-filter-camera');
    var cams = [...new Set(_cam.clips.map(function(c) { return c.camera; }))];
    camFilter.innerHTML = '<option value="all">All Cameras</option>' + cams.map(function(c) { return '<option value="' + c + '">' + _camFmt(c) + '</option>'; }).join('');
    camApplyFilters();
  } catch(e) { document.getElementById('cam-clip-list').innerHTML = '<div class="cam-empty">Failed to load clips</div>'; }
}
function _camRenderClips() {
  var el = document.getElementById('cam-clip-list');
  if (_cam.filteredClips.length === 0) { el.innerHTML = '<div class="cam-empty">No clips found</div>'; return; }
  el.innerHTML = _cam.filteredClips.map(function(clip) {
    var sel = _cam.selectedClips.has(clip.id);
    var label = clip.label.charAt(0).toUpperCase() + clip.label.slice(1);
    var score = clip.score > 0 ? ' \u00b7 ' + clip.score + '%' : '';
    return '<div class="cam-clip-item ' + (sel ? 'selected' : '') + '" onclick="' + (_cam.selectMode ? "camToggleClipSelect('" + clip.id + "')" : "camPlayClip('" + clip.id + "','" + clip.camera + "','" + clip.clip_url + "')") + '">' +
      '<img class="cam-clip-thumb" src="' + clip.thumbnail + '" onerror="this.style.background=\'#0a1428\'" alt="" />' +
      '<div class="cam-clip-info">' +
      '<div class="cam-clip-cam">' + _camFmt(clip.camera) + '</div>' +
      '<div class="cam-clip-type">' + label + score + '</div>' +
      '<div class="cam-clip-meta">' + _camFmtTime(clip.start_time) + ' \u00b7 ' + clip.duration + '</div>' +
      '</div>' +
      (_cam.selectMode ? '<div class="cam-check-circle ' + (sel ? 'checked' : '') + '">\u2713</div>' : '<button class="cam-delete-btn" onclick="event.stopPropagation(); camDeleteClip(\'' + clip.id + '\')">\ud83d\uddd1</button>') +
      '</div>';
  }).join('');
}
function _camUpdateBulkBar() { var btn = document.getElementById('cam-bulk-delete-btn'); if (btn) btn.textContent = 'DELETE SELECTED (' + _cam.selectedClips.size + ')'; }
function camApplyFilters() {
  const cf = document.getElementById('cam-filter-camera').value;
  const lf = document.getElementById('cam-filter-label').value;
  _cam.filteredClips = _cam.clips.filter(c => {
    if (cf !== 'all' && c.camera !== cf) return false;
    if (lf !== 'all' && c.label !== lf) return false;
    return true;
  });
  _camRenderClips();
}
function _camRenderClips() {
  const el = document.getElementById('cam-clip-list');
  if (_cam.filteredClips.length === 0) { el.innerHTML = '<div class="cam-empty">No clips found</div>'; return; }
  el.innerHTML = _cam.filteredClips.map(clip => {
    const sel = _cam.selectedClips.has(clip.id);
    const label = clip.label.charAt(0).toUpperCase() + clip.label.slice(1);
    const score = clip.score > 0 ? ` · ${clip.score}%` : '';
    return `<div class="cam-clip-item ${sel ? 'selected' : ''}" onclick="${_cam.selectMode ? `camToggleClipSelect('${clip.id}')` : `camPlayClip('${clip.id}','${clip.camera}','${clip.clip_url}')`}">
      <img class="cam-clip-thumb" src="${clip.thumbnail}" onerror="this.style.background='#0a1428'" alt="" />
      <div class="cam-clip-info">
        <div class="cam-clip-cam">${_camFmt(clip.camera)}</div>
        <div class="cam-clip-type">${label}${score}</div>
        <div class="cam-clip-meta">${_camFmtTime(clip.start_time)} · ${clip.duration}</div>
      </div>
      ${_cam.selectMode ? `<div class="cam-check-circle ${sel ? 'checked' : ''}">✓</div>` : `<button class="cam-delete-btn" onclick="event.stopPropagation(); camDeleteClip('${clip.id}')">🗑</button>`}
    </div>`;
  }).join('');
}
function camToggleSelectMode() {
  _cam.selectMode = !_cam.selectMode; _cam.selectedClips.clear();
  document.getElementById('cam-select-mode-btn').textContent = _cam.selectMode ? 'CANCEL' : 'SELECT MODE';
  document.getElementById('cam-bulk-bar').style.display = _cam.selectMode ? 'flex' : 'none';
  _camRenderClips();
}
function camSelectAll() { _cam.filteredClips.forEach(c => _cam.selectedClips.add(c.id)); _camUpdateBulkBar(); _camRenderClips(); }
function camToggleClipSelect(id) {
  if (_cam.selectedClips.has(id)) _cam.selectedClips.delete(id); else _cam.selectedClips.add(id);
  _camUpdateBulkBar(); _camRenderClips();
}
function _camUpdateBulkBar() { const btn = document.getElementById('cam-bulk-delete-btn'); if (btn) btn.textContent = `DELETE SELECTED (${_cam.selectedClips.size})`; }
async function camDeleteClip(id) {
  if (!confirm('Delete this clip?')) return;
  await fetch(`/api/clips/${id}`, { method:'DELETE' }).catch(() => {});
  _cam.clips = _cam.clips.filter(c => c.id !== id);
  camApplyFilters();
}
async function camBulkDelete() {
  if (_cam.selectedClips.size === 0) return;
  if (!confirm(`Delete ${_cam.selectedClips.size} clip(s)?`)) return;
  const ids = [..._cam.selectedClips];
  await Promise.all(ids.map(id => fetch(`/api/clips/${id}`, { method:'DELETE' }).catch(() => {})));
  _cam.clips = _cam.clips.filter(c => !ids.includes(c.id));
  _cam.selectedClips.clear(); camToggleSelectMode(); camApplyFilters();
}
function camPlayClip(id, camera, url) {
  document.getElementById('cam-playback-title').textContent = _camFmt(camera) + ' — Clip';
  const vid = document.getElementById('cam-playback-video');
  vid.src = url; vid.play(); _camScreen('playback');
}
function camBackToClips() { const vid = document.getElementById('cam-playback-video'); vid.pause(); vid.src = ''; _camScreen('clips'); }
function camShowSettings() {
  _camScreen('settings');
  camLoadSettings();
}

async function camLoadSettings() {
  var el = document.getElementById('cam-settings-list');
  try {
    var r = await fetch('/api/camera/list');
    var d = await r.json();
    var cams = d.cameras || [];
    if (cams.length === 0) {
      el.innerHTML = '<div style="color:var(--text-sub);font-size:13px;">No cameras configured</div>';
      return;
    }
    el.innerHTML = cams.map(function(cam) {
      return '<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid rgba(var(--accent-rgb),0.1);">' +
        '<div style="width:10px;height:10px;border-radius:50%;flex-shrink:0;background:#22c55e;box-shadow:0 0 6px rgba(34,197,94,0.7);"></div>' +
        '<div style="flex:1;"><div style="font-size:15px;font-weight:700;">' + cam.name + '</div>' +
        '<div style="font-size:12px;color:var(--text-sub);">' + cam.type + ' \u00b7 ' + cam.id + '</div></div></div>';
    }).join('');
  } catch(e) {
    el.innerHTML = '<div style="color:var(--text-sub);font-size:13px;">Failed to load</div>';
  }

  // Load current retention settings
  try {
    var r2 = await fetch('/api/camera/retention');
    var d2 = await r2.json();
    if (d2.continuous) document.getElementById('cam-retain-continuous').value = d2.continuous;
    if (d2.clips) document.getElementById('cam-retain-clips').value = d2.clips;
    if (d2.snapshots) document.getElementById('cam-retain-snapshots').value = d2.snapshots;
  } catch(e) {}
}

async function camSaveRetention() {
  var continuous = document.getElementById('cam-retain-continuous').value;
  var clips = document.getElementById('cam-retain-clips').value;
  var snapshots = document.getElementById('cam-retain-snapshots').value;
  try {
    await fetch('/api/camera/retention', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({continuous: parseInt(continuous), clips: parseInt(clips), snapshots: parseInt(snapshots)})
    });
  } catch(e) { alert('Failed to save'); }
}
</script>



<!-- LIGHTING SUBMENU -->
<style>
  #light-overlay { font-family: 'Rajdhani', sans-serif; color: var(--text); }
  .light-header { display:flex; align-items:center; justify-content:space-between; padding:16px 24px; flex-shrink:0; background:rgba(10,20,60,0.7); border-bottom:1px solid rgba(var(--accent-rgb),0.25); }
  .light-title { font-size:20px; font-weight:700; letter-spacing:2px; color:var(--text); }
  .light-btn { background:rgba(var(--accent-rgb),0.15); border:1px solid rgba(var(--accent-rgb),0.35); color:var(--text); border-radius:8px; padding:8px 18px; font-family:'Rajdhani',sans-serif; font-size:14px; font-weight:700; letter-spacing:1px; cursor:pointer; transition:background 0.2s; }
  .light-btn:hover { background:rgba(var(--accent-rgb),0.3); }
  .light-btn-close { background:rgba(220,40,40,0.12); border-color:rgba(220,40,40,0.35); color:#fca5a5; }
  .light-btn-close:hover { background:rgba(220,40,40,0.28); }
  .light-screen { display:none; flex-direction:column; height:100%; }
  .light-screen.active { display:flex; }
  .light-empty { padding:60px 40px; text-align:center; color:var(--text-sub); font-size:16px; font-weight:600; letter-spacing:1px; line-height:2; }
  .light-empty-icon { font-size:48px; display:block; margin-bottom:16px; opacity:0.4; }
  .light-device-item { display:flex; align-items:center; gap:16px; background:rgba(var(--accent-rgb),0.1); border:1px solid rgba(var(--accent-rgb),0.25); border-radius:10px; padding:16px 20px; cursor:pointer; transition:background 0.2s; }
  .light-device-item:hover { background:rgba(var(--accent-rgb),0.2); }
  .light-device-name { font-size:18px; font-weight:700; flex:1; }
  .light-device-state { font-size:13px; font-weight:700; letter-spacing:1px; }
  .light-device-state.on { color:#22c55e; }
  .light-device-state.off { color:var(--text-sub); }
  .light-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
  .light-dot.on { background:#22c55e; box-shadow:0 0 6px rgba(34,197,94,0.7); }
  .light-dot.off { background:#475569; }
  .light-brightness-bar { height:6px; border-radius:3px; background:rgba(var(--accent-rgb),0.2); flex:1; max-width:120px; overflow:hidden; }
  .light-brightness-fill { height:100%; border-radius:3px; background:#1e5aff; box-shadow:0 0 6px rgba(var(--accent-rgb),0.5); transition:width 0.3s; }
  .light-control-body { flex:1; padding:28px; display:flex; flex-direction:column; gap:28px; overflow-y:auto; }
  .light-control-section { background:rgba(var(--accent-rgb),0.08); border:1px solid rgba(var(--accent-rgb),0.2); border-radius:12px; padding:20px 24px; display:flex; flex-direction:column; gap:16px; }
  .light-section-label { font-size:11px; font-weight:700; letter-spacing:2px; color:var(--text-sub); text-transform:uppercase; }
  .light-toggle-row { display:flex; align-items:center; justify-content:space-between; }
  .light-toggle-label { font-size:18px; font-weight:700; }
  .light-toggle { position:relative; width:56px; height:28px; cursor:pointer; }
  .light-toggle input { opacity:0; width:0; height:0; }
  .light-toggle-slider { position:absolute; inset:0; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); border-radius:28px; transition:0.3s; }
  .light-toggle-slider:before { content:''; position:absolute; height:20px; width:20px; left:3px; bottom:3px; background:var(--text-sub); border-radius:50%; transition:0.3s; }
  .light-toggle input:checked + .light-toggle-slider { background:rgba(34,197,94,0.3); border-color:rgba(34,197,94,0.5); }
  .light-toggle input:checked + .light-toggle-slider:before { transform:translateX(28px); background:#22c55e; box-shadow:0 0 8px rgba(34,197,94,0.7); }
  .light-slider-row { display:flex; flex-direction:column; gap:10px; }
  .light-slider-label-row { display:flex; justify-content:space-between; align-items:center; }
  .light-slider { -webkit-appearance:none; width:100%; height:6px; border-radius:3px; background:rgba(var(--accent-rgb),0.2); outline:none; cursor:pointer; }
  .light-slider::-webkit-slider-thumb { -webkit-appearance:none; width:22px; height:22px; border-radius:50%; background:#1e5aff; box-shadow:0 0 8px rgba(var(--accent-rgb),0.6); cursor:pointer; }
  .light-color-row { display:flex; flex-direction:column; gap:12px; }
  .light-color-swatches { display:flex; gap:10px; flex-wrap:wrap; }
  .light-swatch { width:36px; height:36px; border-radius:50%; cursor:pointer; border:2px solid transparent; transition:all 0.2s; }
  .light-swatch:hover, .light-swatch.active { border-color:#fff; transform:scale(1.15); }
  .light-color-input { width:48px; height:36px; border-radius:8px; border:1px solid rgba(var(--accent-rgb),0.3); cursor:pointer; background:none; padding:2px; }
</style>

<div id="light-overlay" style="display:none; position:fixed; inset:0; background:var(--overlay-bg); z-index:1000; flex-direction:column;">
  <div id="light-screen-list" class="light-screen">
    <div class="light-header">
      <span class="light-title">💡 LIGHTING</span>
      <button class="light-btn light-btn-close" onclick="lightClose()">✕ CLOSE</button>
    </div>
    <div style="flex:1; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:12px;" id="light-device-list"></div>
  </div>
  <div id="light-screen-control" class="light-screen">
    <div class="light-header">
      <span id="light-control-title" class="light-title"></span>
      <div style="display:flex; gap:10px;">
        <button class="light-btn" onclick="lightBackToList()">◀ BACK</button>
        <button class="light-btn light-btn-close" onclick="lightClose()">✕ CLOSE</button>
      </div>
    </div>
    <div class="light-control-body">
      <div class="light-control-section">
        <div class="light-section-label">POWER</div>
        <div class="light-toggle-row">
          <span class="light-toggle-label" id="light-power-label">OFF</span>
          <label class="light-toggle">
            <input type="checkbox" id="light-power-toggle" onchange="lightTogglePower(this)">
            <span class="light-toggle-slider"></span>
          </label>
        </div>
      </div>
      <div class="light-control-section" id="light-dimmer-section">
        <div class="light-section-label">BRIGHTNESS</div>
        <div class="light-slider-row">
          <div class="light-slider-label-row">
            <span style="font-size:14px; color:var(--text-sub);">0%</span>
            <span id="light-brightness-val" style="font-family:'Orbitron',monospace; font-size:18px; font-weight:700;">100%</span>
            <span style="font-size:14px; color:var(--text-sub);">100%</span>
          </div>
          <input type="range" min="0" max="100" value="100" class="light-slider" id="light-brightness-slider" oninput="lightBrightnessChange(this.value)">
        </div>
      </div>
      <div class="light-control-section" id="light-color-section">
        <div class="light-section-label">COLOR</div>
        <div class="light-color-row">
          <div class="light-color-swatches">
            <div class="light-swatch" style="background:#ffffff;" onclick="lightSetColor('#ffffff')"></div>
            <div class="light-swatch" style="background:#ffd580;" onclick="lightSetColor('#ffd580')"></div>
            <div class="light-swatch" style="background:#ff6b35;" onclick="lightSetColor('#ff6b35')"></div>
            <div class="light-swatch" style="background:#ef4444;" onclick="lightSetColor('#ef4444')"></div>
            <div class="light-swatch" style="background:#22c55e;" onclick="lightSetColor('#22c55e')"></div>
            <div class="light-swatch" style="background:#3b82f6;" onclick="lightSetColor('#3b82f6')"></div>
            <div class="light-swatch" style="background:#a855f7;" onclick="lightSetColor('#a855f7')"></div>
            <div class="light-swatch" style="background:#06b6d4;" onclick="lightSetColor('#06b6d4')"></div>
            <input type="color" class="light-color-input" id="light-color-picker" value="#ffffff" onchange="lightSetColor(this.value)">
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const _light = { devices: [], currentDevice: null };
function _lightFmt(name) { return name.replace(/[-_]/g, ' ').replace(/\b\w/g, c => c.toUpperCase()); }
function _lightScreen(id) {
  document.querySelectorAll('.light-screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById('light-screen-' + id);
  if (el) el.classList.add('active');
}
async function lightOpen() {
  const overlay = document.getElementById('light-overlay');
  overlay.style.display = 'flex';
  overlay.style.flexDirection = 'column';
  _lightScreen('list');
  try {
    const r = await fetch('/api/lights');
    const data = await r.json();
    _light.devices = data.devices || [];
  } catch(e) { _light.devices = []; }
  _lightRenderList();
}
function lightClose() { if(_isMobile()) return _mobileClose(); document.getElementById('light-overlay').style.display = 'none'; }
function lightBackToList() { _lightScreen('list'); _lightRenderList(); }
function _lightRenderList() {
  const el = document.getElementById('light-device-list');
  if (!el) return;
  if (_light.devices.length === 0) {
    el.innerHTML = '<div class="light-empty"><span class="light-empty-icon">💡</span>No lighting devices registered.<br>Devices will appear here automatically<br>when connected via MQTT.</div>';
    return;
  }
  el.innerHTML = _light.devices.map((dev, i) => {
    const isOn = dev.state === 'on';
    const brightness = dev.brightness !== undefined ? dev.brightness : 100;
    return '<div class="light-device-item" onclick="lightOpenControl(' + i + ')">' +
      '<div class="light-dot ' + (isOn ? 'on' : 'off') + '"></div>' +
      '<span class="light-device-name">' + _lightFmt(dev.name) + '</span>' +
      (dev.type === 'dimmer' || dev.type === 'rgb' ? '<div class="light-brightness-bar"><div class="light-brightness-fill" style="width:' + (isOn ? brightness : 0) + '%"></div></div>' : '') +
      '<span class="light-device-state ' + (isOn ? 'on' : 'off') + '">' + (isOn ? 'ON' : 'OFF') + '</span></div>';
  }).join('');
}
</script>

<script>
function lightOpenControl(idx) {
  _light.currentDevice = _light.devices[idx];
  const dev = _light.currentDevice;
  document.getElementById('light-control-title').textContent = '💡 ' + _lightFmt(dev.name);
  const isOn = dev.state === 'on';
  const toggle = document.getElementById('light-power-toggle');
  toggle.checked = isOn;
  document.getElementById('light-power-label').textContent = isOn ? 'ON' : 'OFF';
  const brightness = dev.brightness !== undefined ? dev.brightness : 100;
  document.getElementById('light-brightness-slider').value = brightness;
  document.getElementById('light-brightness-val').textContent = brightness + '%';
  document.getElementById('light-dimmer-section').style.display = (dev.type === 'dimmer' || dev.type === 'rgb') ? 'flex' : 'none';
  document.getElementById('light-color-section').style.display = dev.type === 'rgb' ? 'flex' : 'none';
  if (dev.color) document.getElementById('light-color-picker').value = dev.color;
  _lightScreen('control');
}
async function lightTogglePower(el) {
  const dev = _light.currentDevice;
  if (!dev) return;
  const state = el.checked ? 'on' : 'off';
  document.getElementById('light-power-label').textContent = state.toUpperCase();
  dev.state = state;
  try {
    await fetch('/api/lights/' + dev.id + '/control', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ action: 'state', value: state })
    });
  } catch(e) {}
}
async function lightBrightnessChange(val) {
  document.getElementById('light-brightness-val').textContent = val + '%';
  const dev = _light.currentDevice;
  if (!dev) return;
  dev.brightness = parseInt(val);
  try {
    await fetch('/api/lights/' + dev.id + '/control', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ action: 'brightness', value: parseInt(val) })
    });
  } catch(e) {}
}
async function lightSetColor(hex) {
  document.querySelectorAll('.light-swatch').forEach(s => s.classList.remove('active'));
  const dev = _light.currentDevice;
  if (!dev) return;
  dev.color = hex;
  document.getElementById('light-color-picker').value = hex;
  try {
    await fetch('/api/lights/' + dev.id + '/control', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ action: 'color', value: hex })
    });
  } catch(e) {}
}
</script>

<!-- OPERATIONS SUBMENU -->
<style>
#ops-overlay{font-family:'Rajdhani',sans-serif;color:var(--text);}
.ops-header{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;flex-shrink:0;background:rgba(10,20,60,0.7);border-bottom:1px solid rgba(var(--accent-rgb),0.25);}
.ops-title{font-size:20px;font-weight:700;letter-spacing:2px;color:var(--text);}
.ops-btn{background:rgba(var(--accent-rgb),0.15);border:1px solid rgba(var(--accent-rgb),0.35);color:var(--text);border-radius:8px;padding:8px 18px;font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;letter-spacing:1px;cursor:pointer;transition:background 0.2s;}
.ops-btn:hover{background:rgba(var(--accent-rgb),0.3);}
.ops-btn-close{background:rgba(220,40,40,0.12);border-color:rgba(220,40,40,0.35);color:#fca5a5;}
.ops-btn-close:hover{background:rgba(220,40,40,0.28);}
.ops-screen{display:none;flex-direction:column;height:100%;}
.ops-screen.active{display:flex;}
.ops-system-item{display:flex;align-items:center;gap:16px;background:rgba(var(--accent-rgb),0.1);border:1px solid rgba(var(--accent-rgb),0.25);border-radius:10px;padding:16px 20px;cursor:pointer;transition:background 0.2s;}
.ops-system-item:hover{background:rgba(var(--accent-rgb),0.2);}
.ops-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.ops-dot-on{background:#22c55e;box-shadow:0 0 6px rgba(34,197,94,0.7);}
.ops-dot-off{background:#ef4444;}
.ops-section{background:rgba(var(--accent-rgb),0.08);border:1px solid rgba(var(--accent-rgb),0.2);border-radius:12px;padding:18px 22px;display:flex;flex-direction:column;gap:12px;}
.ops-section-label{font-size:11px;font-weight:700;letter-spacing:2px;color:var(--text-sub);text-transform:uppercase;}
.ops-reading-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.ops-reading-card{display:flex;flex-direction:column;align-items:center;padding:12px 8px;background:rgba(var(--accent-rgb),0.12);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.25);}
.ops-reading-label{font-size:12px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;font-weight:600;}
.ops-reading-val{font-family:'Orbitron',monospace;font-size:22px;color:var(--text);font-weight:700;}
.ops-reading-trend{font-size:11px;font-weight:700;margin-top:2px;}
.ops-reading-big{grid-column:1/-1;padding:16px 8px;}
.ops-reading-big .ops-reading-val{font-size:36px;}
.ops-stat-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid rgba(var(--accent-rgb),0.1);}
.ops-stat-row:last-child{border-bottom:none;}
.ops-stat-label{font-size:14px;color:var(--text-sub);font-weight:600;}
.ops-stat-val{font-family:'Orbitron',monospace;font-size:15px;font-weight:700;color:var(--text);}
.ops-graph-wrap{background:rgba(0,0,0,0.3);border:1px solid rgba(var(--accent-rgb),0.15);border-radius:8px;padding:12px;height:200px;position:relative;}
.ops-range-bar{display:flex;gap:6px;margin-bottom:8px;}
.ops-range-btn{background:rgba(var(--accent-rgb),0.1);border:1px solid rgba(var(--accent-rgb),0.25);color:var(--text-sub);border-radius:6px;padding:4px 10px;font-family:'Rajdhani',sans-serif;font-size:12px;font-weight:700;cursor:pointer;}
.ops-range-btn.active{background:rgba(var(--accent-rgb),0.35);border-color:var(--accent);color:var(--text);}
.ops-empty{padding:40px;text-align:center;color:var(--text-sub);font-size:16px;font-weight:600;letter-spacing:1px;line-height:2;}
.ops-empty-icon{font-size:48px;display:block;margin-bottom:16px;opacity:0.4;}
</style>

<div id="ops-overlay" style="display:none;position:fixed;inset:0;background:var(--overlay-bg);z-index:1000;flex-direction:column;">

<!-- SYSTEM LIST -->
<div id="ops-screen-list" class="ops-screen">
<div class="ops-header">
<span class="ops-title">&#9881;&#65039; OPERATIONS</span>
<button class="ops-btn ops-btn-close" onclick="opsClose()">&#10005; CLOSE</button>
</div>
<div style="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:12px;" id="ops-system-list"></div>
</div>

<!-- SYSTEM DETAIL -->
<div id="ops-screen-detail" class="ops-screen">
<div class="ops-header">
<span id="ops-detail-title" class="ops-title"></span>
<div style="display:flex;gap:10px;">
<button class="ops-btn" onclick="opsBackToList()">&#9664; BACK</button>
<button class="ops-btn ops-btn-close" onclick="opsClose()">&#10005; CLOSE</button>
</div>
</div>
<div id="ops-detail-body" style="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px;"></div>
</div>

<!-- HISTORY / GRAPHS -->
<div id="ops-screen-history" class="ops-screen">
<div class="ops-header">
<span id="ops-history-title" class="ops-title">&#128200; HISTORY</span>
<div style="display:flex;gap:10px;">
<button class="ops-btn" onclick="opsBackToDetail()">&#9664; BACK</button>
<button class="ops-btn ops-btn-close" onclick="opsClose()">&#10005; CLOSE</button>
</div>
</div>
<div style="padding:12px 20px 0;display:flex;gap:8px;flex-shrink:0;">
<select class="ops-btn" id="ops-hist-sensor" onchange="opsLoadGraph()" style="flex:1;">
<option value="rak_temp">Temperature</option>
<option value="rak_humidity">Humidity</option>
<option value="rak_pressure">Barometric Pressure</option>
<option value="rak_airquality">Air Quality</option>
<option value="rak_dewpoint">Dew Point</option>
</select>
</div>
<div class="ops-range-bar" style="padding:8px 20px 0;" id="ops-hist-range">
<button class="ops-range-btn active" onclick="opsSetHistRange('24h',this)">24H</button>
<button class="ops-range-btn" onclick="opsSetHistRange('7d',this)">7D</button>
<button class="ops-range-btn" onclick="opsSetHistRange('30d',this)">30D</button>
<button class="ops-range-btn" onclick="opsSetHistRange('6m',this)">6M</button>
<button class="ops-range-btn" onclick="opsSetHistRange('1y',this)">1Y</button>
</div>
<div style="padding:12px 20px;flex:1;display:flex;flex-direction:column;min-height:0;">
<div class="ops-graph-wrap" style="flex:1;">
<canvas id="ops-hist-canvas"></canvas>
</div>
<div id="ops-hist-stats" style="margin-top:12px;"></div>
</div>
</div>

</div>

<script>
var _ops = { systems: [], currentSystem: null, currentRange: '24h', histChart: null };

function _opsScreen(id) {
  document.querySelectorAll('.ops-screen').forEach(function(s) { s.classList.remove('active'); });
  var el = document.getElementById('ops-screen-' + id);
  if (el) el.classList.add('active');
}

function _opsFmt(name) {
  return name.replace(/[-_]/g, ' ').replace(/\w/g, function(c) { return c.toUpperCase(); });
}

async function opsOpen() {
  var overlay = document.getElementById('ops-overlay');
  overlay.style.display = 'flex';
  overlay.style.flexDirection = 'column';
  _opsScreen('list');
  try {
    var r = await fetch('/api/systems');
    var d = await r.json();
    _ops.systems = d.systems || [];
  } catch(e) { _ops.systems = []; }
  _opsRenderList();
}

function opsClose() {
  if (typeof _isMobile === 'function' && _isMobile()) return _mobileClose();
  document.getElementById('ops-overlay').style.display = 'none';
}

function opsBackToList() { _opsScreen('list'); _opsRenderList(); }
function opsBackToDetail() { _opsScreen('detail'); }

function _opsRenderList() {
  var el = document.getElementById('ops-system-list');
  if (_ops.systems.length === 0) {
    el.innerHTML = '<div class="ops-empty"><span class="ops-empty-icon">&#9881;&#65039;</span>No systems registered.<br>Systems appear automatically when connected.</div>';
    return;
  }
  el.innerHTML = _ops.systems.map(function(sys, i) {
    var online = sys.online === true || sys.online === 1;
    return '<div class="ops-system-item" onclick="opsOpenDetail(' + i + ')">' +
      '<div class="ops-dot ' + (online ? 'ops-dot-on' : 'ops-dot-off') + '"></div>' +
      '<div style="flex:1;"><div style="font-size:18px;font-weight:700;">' + _opsFmt(sys.name) + '</div>' +
      '<div style="font-size:13px;color:var(--text-sub);">' + (sys.summary || sys.type || '') + '</div></div>' +
      '<span style="font-size:11px;font-weight:700;letter-spacing:1px;padding:3px 10px;border-radius:4px;' +
      (online ? 'color:#22c55e;background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.3);' : 'color:#f87171;background:rgba(220,40,40,0.12);border:1px solid rgba(220,40,40,0.3);') +
      '">' + (online ? 'ONLINE' : 'OFFLINE') + '</span></div>';
  }).join('');
}

async function opsOpenDetail(idx) {
  _ops.currentSystem = _ops.systems[idx];
  var sys = _ops.currentSystem;
  document.getElementById('ops-detail-title').textContent = _opsFmt(sys.name);

  if (sys.type === 'weather_station' || sys.id === 'rak_weather_station') {
    await _opsRenderWeatherStation();
  } else {
    _opsRenderGenericSystem(sys);
  }
  _opsScreen('detail');
}

async function _opsRenderWeatherStation() {
  var body = document.getElementById('ops-detail-body');
  body.innerHTML = '<div class="ops-empty">Loading...</div>';

  // Fetch current readings
  var readings = {};
  try {
    var r = await fetch('/api/sensors');
    var d = await r.json();
    (d.sensors || []).forEach(function(s) { readings[s.id] = s; });
  } catch(e) {}

  // Fetch averages
  var avgs = {};
  try {
    var r2 = await fetch('/api/sensors/averages');
    avgs = await r2.json();
  } catch(e) {}

  var temp = readings.rak_temp;
  var humid = readings.rak_humidity;
  var pres = readings.rak_pressure;
  var aqi = readings.rak_airquality;
  var dew = readings.rak_dewpoint;

  var lastSeen = '';
  if (temp && temp.last_seen) {
    var diff = Math.floor(Date.now()/1000 - temp.last_seen);
    if (diff < 60) lastSeen = diff + 's ago';
    else if (diff < 3600) lastSeen = Math.floor(diff/60) + 'm ago';
    else lastSeen = Math.floor(diff/3600) + 'h ago';
  }

  var html = '';

  // Status
  html += '<div class="ops-section"><div class="ops-section-label">STATUS</div>';
  html += '<div class="ops-stat-row"><span class="ops-stat-label">Connection</span><span class="ops-stat-val" style="color:#22c55e;">Online</span></div>';
  html += '<div class="ops-stat-row"><span class="ops-stat-label">Last Reading</span><span class="ops-stat-val">' + (lastSeen || '—') + '</span></div>';
  html += '<div class="ops-stat-row"><span class="ops-stat-label">Device</span><span class="ops-stat-val" style="font-family:Rajdhani,sans-serif;">RAK4631 + RAK1906</span></div>';
  html += '<div class="ops-stat-row"><span class="ops-stat-label">Interface</span><span class="ops-stat-val" style="font-family:Rajdhani,sans-serif;">USB /dev/ttyACM0</span></div>';
  html += '</div>';

  // Live readings
  html += '<div class="ops-section"><div class="ops-section-label">LIVE READINGS</div>';
  html += '<div class="ops-reading-grid">';
  html += '<div class="ops-reading-card ops-reading-big"><div class="ops-reading-label">Temperature</div><div class="ops-reading-val">' + (temp ? temp.last_value + '\u00b0F' : '—') + '</div></div>';
  html += '<div class="ops-reading-card"><div class="ops-reading-label">Humidity</div><div class="ops-reading-val">' + (humid ? humid.last_value + '%' : '—') + '</div></div>';
  html += '<div class="ops-reading-card"><div class="ops-reading-label">Barometric</div><div class="ops-reading-val">' + (pres ? pres.last_value + '</div><div class="ops-reading-label" style="font-size:10px;">hPa</div>' : '—</div>') + '</div>';
  html += '<div class="ops-reading-card"><div class="ops-reading-label">Air Quality</div><div class="ops-reading-val">' + (aqi ? Math.round(aqi.last_value) + '</div><div class="ops-reading-label" style="font-size:10px;">IAQ</div>' : '—</div>') + '</div>';
  html += '<div class="ops-reading-card"><div class="ops-reading-label">Dew Point</div><div class="ops-reading-val">' + (dew ? dew.last_value + '\u00b0F' : '—') + '</div></div>';
  html += '</div></div>';

  // Averages
  html += '<div class="ops-section"><div class="ops-section-label">AVERAGES</div>';
  html += '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:8px;">';
  html += '<div class="ops-avg-cell"><div class="ops-avg-label">24h Avg</div><div class="ops-avg-val">' + (avgs.temp_24h || '—') + '</div></div>';
  html += '<div class="ops-avg-cell"><div class="ops-avg-label">7d Avg</div><div class="ops-avg-val">' + (avgs.temp_7d || '—') + '</div></div>';
  html += '<div class="ops-avg-cell"><div class="ops-avg-label">30d Avg</div><div class="ops-avg-val">' + (avgs.temp_30d || '—') + '</div></div>';
  html += '<div class="ops-avg-cell"><div class="ops-avg-label">Humidity</div><div class="ops-avg-val">' + (avgs.humid_24h || '—') + '</div></div>';
  html += '<div class="ops-avg-cell"><div class="ops-avg-label">24h High</div><div class="ops-avg-val" style="color:#ef4444;">' + (avgs.temp_24h_high || '—') + '</div></div>';
  html += '<div class="ops-avg-cell"><div class="ops-avg-label">24h Low</div><div class="ops-avg-val" style="color:#3b82f6;">' + (avgs.temp_24h_low || '—') + '</div></div>';
  html += '<div class="ops-avg-cell"><div class="ops-avg-label">Pressure</div><div class="ops-avg-val">' + (avgs.pres_24h || '—') + '</div></div>';
  html += '<div class="ops-avg-cell"><div class="ops-avg-label">Dew Pt Avg</div><div class="ops-avg-val">' + (avgs.dew_24h || '—') + '</div></div>';
  html += '</div></div>';
  html += '</div>';

  // History button
  html += '<button class="ops-btn" onclick="opsShowHistory()" style="width:100%;padding:14px;font-size:16px;">&#128200; VIEW FULL HISTORY</button>';

  body.innerHTML = html;
}

function _opsRenderGenericSystem(sys) {
  var body = document.getElementById('ops-detail-body');
  var online = sys.online === true || sys.online === 1;

  var html = '<div class="ops-section"><div class="ops-section-label">CONNECTION</div>';
  html += '<div class="ops-stat-row"><span class="ops-stat-label">Status</span><span class="ops-stat-val" style="color:' + (online ? '#22c55e' : '#f87171') + ';">' + (online ? 'ONLINE' : 'OFFLINE') + '</span></div>';
  if (sys.ip) html += '<div class="ops-stat-row"><span class="ops-stat-label">IP</span><span class="ops-stat-val" style="font-family:Rajdhani,sans-serif;">' + sys.ip + '</span></div>';
  if (sys.uptime) html += '<div class="ops-stat-row"><span class="ops-stat-label">Uptime</span><span class="ops-stat-val" style="font-family:Rajdhani,sans-serif;">' + sys.uptime + '</span></div>';
  if (sys.rssi) html += '<div class="ops-stat-row"><span class="ops-stat-label">Signal</span><span class="ops-stat-val">' + sys.rssi + ' dBm</span></div>';
  html += '</div>';

  if (sys.sensors && sys.sensors.length > 0) {
    html += '<div class="ops-section"><div class="ops-section-label">SENSORS</div>';
    sys.sensors.forEach(function(s) {
      html += '<div class="ops-stat-row"><span class="ops-stat-label">' + s.name + '</span><span class="ops-stat-val">' + s.value + ' ' + (s.unit || '') + '</span></div>';
    });
    html += '</div>';
  }

  if (sys.controls && sys.controls.length > 0) {
    html += '<div class="ops-section"><div class="ops-section-label">CONTROLS</div>';
    sys.controls.forEach(function(ctrl) {
      if (ctrl.type === 'toggle') {
        html += '<div class="ops-stat-row"><span class="ops-stat-label">' + ctrl.name + '</span>' +
          '<label class="auto-toggle"><input type="checkbox" ' + (ctrl.state === 'on' ? 'checked' : '') +
          ' onchange="opsControl(\'' + sys.id + '\',\'' + ctrl.id + '\',\'toggle\',this.checked)"><span class="auto-toggle-slider"></span></label></div>';
      } else if (ctrl.type === 'momentary') {
        html += '<div class="ops-stat-row"><span class="ops-stat-label">' + ctrl.name + '</span>' +
          '<button class="ops-btn" onclick="opsControl(\'' + sys.id + '\',\'' + ctrl.id + '\',\'momentary\',true)">' + (ctrl.label || 'PRESS') + '</button></div>';
      }
    });
    html += '</div>';
  }

  body.innerHTML = html;
}

async function opsControl(sysId, controlId, type, value) {
  try {
    await fetch('/api/systems/' + sysId + '/control', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ control_id: controlId, type: type, value: value })
    });
  } catch(e) {}
}

function opsShowHistory() {
  _ops.currentRange = '24h';
  document.querySelectorAll('#ops-hist-range .ops-range-btn').forEach(function(b) { b.classList.remove('active'); });
  document.querySelector('#ops-hist-range .ops-range-btn').classList.add('active');
  _opsScreen('history');
  opsLoadGraph();
}

function opsSetHistRange(range, btn) {
  _ops.currentRange = range;
  document.querySelectorAll('#ops-hist-range .ops-range-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  opsLoadGraph();
}

async function opsLoadGraph() {
  var sensor = document.getElementById('ops-hist-sensor').value;
  var range = _ops.currentRange;

  try {
    var r = await fetch('/api/sensors/' + sensor + '/history?range=' + range);
    var d = await r.json();
    var points = d.points || [];

    if (points.length === 0) {
      document.getElementById('ops-hist-stats').innerHTML = '<div style="color:var(--text-sub);text-align:center;">No data for this range</div>';
      return;
    }

    // Calculate stats
    var values = points.map(function(p) { return p.v; });
    var high = Math.max.apply(null, values);
    var low = Math.min.apply(null, values);
    var sum = values.reduce(function(a, b) { return a + b; }, 0);
    var avg = sum / values.length;

    var sensorInfo = {rak_temp: '\u00b0F', rak_humidity: '%', rak_pressure: ' hPa', rak_airquality: ' IAQ', rak_dewpoint: '\u00b0F'};
    var unit = sensorInfo[sensor] || '';

    document.getElementById('ops-hist-stats').innerHTML =
      '<div class="ops-section"><div class="ops-section-label">STATISTICS (' + range.toUpperCase() + ')</div>' +
      '<div class="ops-stat-row"><span class="ops-stat-label">High</span><span class="ops-stat-val" style="color:#ef4444;">' + high.toFixed(1) + unit + '</span></div>' +
      '<div class="ops-stat-row"><span class="ops-stat-label">Low</span><span class="ops-stat-val" style="color:#3b82f6;">' + low.toFixed(1) + unit + '</span></div>' +
      '<div class="ops-stat-row"><span class="ops-stat-label">Average</span><span class="ops-stat-val">' + avg.toFixed(1) + unit + '</span></div>' +
      '<div class="ops-stat-row"><span class="ops-stat-label">Readings</span><span class="ops-stat-val" style="font-family:Rajdhani,sans-serif;">' + values.length + '</span></div>' +
      '</div>';

    // Draw chart
    var canvas = document.getElementById('ops-hist-canvas');
    var wrap = canvas.parentElement;
    canvas.width = wrap.clientWidth - 24;
    canvas.height = wrap.clientHeight - 24;
    var ctx = canvas.getContext('2d');

    if (_ops.histChart) {
      _ops.histChart.destroy();
      _ops.histChart = null;
    }

    var labels = points.map(function(p) {
      var dt = new Date(p.t * 1000);
      if (range === '24h') return dt.getHours() + ':' + String(dt.getMinutes()).padStart(2, '0');
      return (dt.getMonth()+1) + '/' + dt.getDate();
    });

    // Downsample if too many points
    var maxPoints = 200;
    var step = Math.max(1, Math.floor(points.length / maxPoints));
    var dsLabels = [];
    var dsValues = [];
    for (var i = 0; i < points.length; i += step) {
      dsLabels.push(labels[i]);
      dsValues.push(values[i]);
    }

    _ops.histChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: dsLabels,
        datasets: [{
          data: dsValues,
          borderColor: 'rgba(30,90,255,0.8)',
          backgroundColor: 'rgba(30,90,255,0.1)',
          fill: true,
          tension: 0.3,
          pointRadius: 0,
          borderWidth: 2
        }]
      },
      options: {
        responsive: false,
        plugins: { legend: { display: false } },
        scales: {
          x: {
            ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 }, maxTicksLimit: 8 },
            grid: { color: 'rgba(255,255,255,0.05)' }
          },
          y: {
            ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 } },
            grid: { color: 'rgba(255,255,255,0.08)' }
          }
        }
      }
    });

  } catch(e) {
    document.getElementById('ops-hist-stats').innerHTML = '<div style="color:#f87171;text-align:center;">Failed to load data</div>';
  }
}
</script>

<!-- SETTINGS SUBMENU -->
<style>
  #settings-overlay { font-family: 'Rajdhani', sans-serif; color: var(--text); }
  .settings-header { display:flex; align-items:center; justify-content:space-between; padding:16px 24px; flex-shrink:0; background:rgba(10,20,60,0.7); border-bottom:1px solid rgba(var(--accent-rgb),0.25); }
  .settings-title { font-size:20px; font-weight:700; letter-spacing:2px; color:var(--text); }
  .settings-btn { background:rgba(var(--accent-rgb),0.15); border:1px solid rgba(var(--accent-rgb),0.35); color:var(--text); border-radius:8px; padding:8px 18px; font-family:'Rajdhani',sans-serif; font-size:14px; font-weight:700; letter-spacing:1px; cursor:pointer; transition:background 0.2s; }
  .settings-btn:hover { background:rgba(var(--accent-rgb),0.3); }
  .settings-btn-close { background:rgba(220,40,40,0.12); border-color:rgba(220,40,40,0.35); color:#fca5a5; }
  .settings-btn-close:hover { background:rgba(220,40,40,0.28); }
  .settings-screen { display:none; flex-direction:column; height:100%; }
  .settings-screen.active { display:flex; }
  .settings-body { flex:1; padding:24px; display:flex; flex-direction:column; gap:16px; overflow-y:auto; }
  .settings-section { background:rgba(var(--accent-rgb),0.08); border:1px solid rgba(var(--accent-rgb),0.2); border-radius:12px; padding:20px 24px; display:flex; flex-direction:column; gap:16px; }
  .settings-section-label { font-size:11px; font-weight:700; letter-spacing:2px; color:var(--text-sub); text-transform:uppercase; margin-bottom:4px; }
  .settings-row { display:flex; align-items:center; justify-content:space-between; padding:6px 0; }
  .settings-row-label { font-size:16px; font-weight:700; color:var(--text); }
  .settings-row-sub { font-size:13px; color:var(--text-sub); font-weight:600; margin-top:2px; }
  .settings-slider { -webkit-appearance:none; width:200px; height:6px; border-radius:3px; background:rgba(var(--accent-rgb),0.2); outline:none; cursor:pointer; }
  .settings-slider::-webkit-slider-thumb { -webkit-appearance:none; width:22px; height:22px; border-radius:50%; background:#1e5aff; box-shadow:0 0 8px rgba(var(--accent-rgb),0.6); cursor:pointer; }
  .settings-val { font-family:'Orbitron',monospace; font-size:15px; font-weight:700; min-width:48px; text-align:right; }
  .settings-toggle { position:relative; width:56px; height:28px; cursor:pointer; flex-shrink:0; }
  .settings-toggle input { opacity:0; width:0; height:0; }
  .settings-toggle-slider { position:absolute; inset:0; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); border-radius:28px; transition:0.3s; }
  .settings-toggle-slider:before { content:''; position:absolute; height:20px; width:20px; left:3px; bottom:3px; background:var(--text-sub); border-radius:50%; transition:0.3s; }
  .settings-toggle input:checked + .settings-toggle-slider { background:rgba(34,197,94,0.3); border-color:rgba(34,197,94,0.5); }
  .settings-toggle input:checked + .settings-toggle-slider:before { transform:translateX(28px); background:#22c55e; box-shadow:0 0 8px rgba(34,197,94,0.7); }
  .settings-select { background:rgba(var(--accent-rgb),0.12); border:1px solid rgba(var(--accent-rgb),0.3); color:var(--text); border-radius:8px; padding:8px 14px; font-family:'Rajdhani',sans-serif; font-size:15px; font-weight:600; cursor:pointer; }
  .settings-select option { background:#0a1428; }
  .settings-theme-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
  .settings-theme-btn { background:rgba(var(--accent-rgb),0.1); border:1px solid rgba(var(--accent-rgb),0.25); border-radius:10px; padding:14px 8px; cursor:pointer; text-align:center; font-family:'Rajdhani',sans-serif; font-size:13px; font-weight:700; color:var(--text); transition:all 0.2s; }
  .settings-theme-btn:hover { background:rgba(var(--accent-rgb),0.25); }
  .settings-theme-btn.active { border-color:#1e5aff; box-shadow:0 0 10px rgba(var(--accent-rgb),0.4); }
  .settings-theme-swatch { width:32px; height:32px; border-radius:50%; margin:0 auto 8px; border:2px solid rgba(255,255,255,0.2); }
</style>

<style>.settings-menu-item{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:rgba(var(--accent-rgb),0.08);border:1px solid rgba(var(--accent-rgb),0.2);border-radius:12px;cursor:pointer;transition:background 0.2s;}.settings-menu-item:hover{background:rgba(var(--accent-rgb),0.18);}</style>
<div id="settings-overlay" style="display:none;position:fixed;inset:0;background:var(--overlay-bg);z-index:1000;flex-direction:column;">
<div id="settings-screen-main" class="settings-screen"><div class="settings-header"><span class="settings-title">🔧 SETTINGS</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body"><div class="settings-menu-item" onclick="settingsNav('display')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">🖥</span><div><div class="settings-row-label">Display</div><div class="settings-row-sub">Brightness and screen power</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('screensaver')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">🌅</span><div><div class="settings-row-label">Screensaver</div><div class="settings-row-sub">Photos, timeout, transitions</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('themes')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">🎨</span><div><div class="settings-row-label">Themes</div><div class="settings-row-sub">Visual themes and holidays</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('timedate')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">🕐</span><div><div class="settings-row-label">Time & Date</div><div class="settings-row-sub">Clock and date settings</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('network')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">📡</span><div><div class="settings-row-label">Network</div><div class="settings-row-sub">Network information</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('system')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">💾</span><div><div class="settings-row-label">System</div><div class="settings-row-sub">System settings</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>


<div class="settings-menu-item" onclick="settingsNav('devices')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">📱</span><div><div class="settings-row-label">Devices</div><div class="settings-row-sub">Registered devices</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('notifications')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">🔔</span><div><div class="settings-row-label">Notifications</div><div class="settings-row-sub">Alert preferences</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('about')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">ℹ️</span><div><div class="settings-row-label">About</div><div class="settings-row-sub">System info and version</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
</div></div>
<div id="settings-screen-display" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('main')">◀ BACK</button><span class="settings-title">🖥 DISPLAY</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body"><div class="settings-section">
<div class="settings-row"><div><div class="settings-row-label">Brightness</div><div class="settings-row-sub">Screen backlight level</div></div>
<div style="display:flex;align-items:center;gap:12px;"><input type="range" min="0" max="100" value="80" class="settings-slider" id="settings-brightness-slider" oninput="settingsBrightness(this.value)"><span class="settings-val" id="settings-brightness-val">80%</span></div></div>
<div class="settings-row"><div><div class="settings-row-label">Display Power</div><div class="settings-row-sub">Turn screen on or off</div></div>
<div style="display:flex;gap:10px;"><button class="settings-btn" onclick="settingsDisplayOn()">ON</button><button class="settings-btn" onclick="settingsDisplayOff()">OFF</button></div></div>
</div></div></div>
<div id="settings-screen-screensaver" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('main')">◀ BACK</button><span class="settings-title">🌅 SCREENSAVER</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body"><div class="settings-section">
<div class="settings-row"><div><div class="settings-row-label">Timeout</div><div class="settings-row-sub">Inactivity before screensaver</div></div>
<select class="settings-select" id="settings-ss-timeout"><option value="15">15 seconds</option><option value="30">30 seconds</option><option value="60" selected>1 minute</option><option value="120">2 minutes</option><option value="300">5 minutes</option><option value="0">Disabled</option></select></div>
<div class="settings-row"><div><div class="settings-row-label">Photo Duration</div><div class="settings-row-sub">Time per photo</div></div>
<select class="settings-select" id="settings-ss-duration"><option value="3">3 seconds</option><option value="5" selected>5 seconds</option><option value="10">10 seconds</option><option value="15">15 seconds</option><option value="30">30 seconds</option></select></div>
<div class="settings-row"><div><div class="settings-row-label">Clock Overlay</div><div class="settings-row-sub">Show time over photos</div></div>
<label class="settings-toggle"><input type="checkbox" id="settings-ss-clock"><span class="settings-toggle-slider"></span></label></div>
<div class="settings-row"><div><div class="settings-row-label">Album</div><div class="settings-row-sub">Which photo album to display</div></div>
<select class="settings-select" id="settings-ss-album" onchange="settingsSaveAlbum(this.value)"><option value="1">Album 1</option><option value="2">Album 2</option><option value="3">Album 3</option><option value="4">Album 4</option><option value="5">Album 5</option></select></div>
</div></div></div>
<div id="settings-screen-themes" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('main')">◀ BACK</button><span class="settings-title">🎨 THEMES</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body"><div class="settings-section" style="display:flex;flex-direction:column;gap:14px;">
<div class="settings-menu-item" onclick="settingsNav('themes_list')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">🎨</span><div><div class="settings-row-label">Themes</div><div class="settings-row-sub">Select visual theme</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('holiday_themes')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">🎄</span><div><div class="settings-row-label">Holiday Themes</div><div class="settings-row-sub">Seasonal theme schedule</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('theme_schedule')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">📅</span><div><div class="settings-row-label">Schedule</div><div class="settings-row-sub">Auto-switch themes by date</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
<div class="settings-menu-item" onclick="settingsNav('theme_carousel')"><div style="display:flex;align-items:center;gap:14px;"><span style="font-size:22px;">🎠</span><div><div class="settings-row-label">Carousel</div><div class="settings-row-sub">Auto-cycle themes on a timer</div></div></div><span style="color:var(--text-sub);font-size:18px;">▶</span></div>
</div></div></div>
<div id="settings-screen-theme_schedule" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('themes')">◀ BACK</button><span class="settings-title">📅 SCHEDULE</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body"><div style="display:flex;justify-content:flex-end;margin-bottom:8px;"><button class="settings-btn" onclick="scheduleShowCreate()">+ NEW</button></div><div id="schedule-list"></div></div></div>
<div id="settings-screen-theme_carousel" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('themes')">◀ BACK</button><span class="settings-title">🎠 CAROUSEL</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body"><div class="settings-section" style="gap:16px;"><div class="settings-row"><div><div class="settings-row-label">Auto-Cycle Themes</div><div class="settings-row-sub">Cycles through all regular themes</div></div><label class="settings-toggle"><input type="checkbox" id="carousel-toggle" onchange="carouselToggle(this.checked)"><span class="settings-toggle-slider"></span></label></div><div class="settings-row"><div><div class="settings-row-label">Change Every</div></div><div style="display:flex;gap:8px;align-items:center;"><input type="number" class="auto-input" id="carousel-val" value="1" min="1" style="width:80px;" onchange="carouselSave()"><select class="auto-select" id="carousel-unit" onchange="carouselSave()"><option value="60000">Minutes</option><option value="3600000" selected>Hours</option><option value="86400000">Days</option><option value="604800000">Weeks</option></select></div></div></div></div></div>
<div id="settings-screen-themes_list" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('themes')">◀ BACK</button><span class="settings-title">🎨 THEMES</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body"><div class="settings-section"><div class="settings-theme-grid" id="settings-theme-grid"></div></div></div></div>
<div id="settings-screen-holiday_themes" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('themes')">◀ BACK</button><span class="settings-title">🎄 HOLIDAY THEMES</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body"><div class="settings-section"><div class="settings-theme-grid" id="settings-holiday-grid"></div></div></div></div>
<div id="settings-screen-about" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('main')">◀ BACK</button><span class="settings-title">ℹ ABOUT</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body"><div class="settings-section">
<div class="settings-section-label">DASHBOARD</div>
<div class="settings-row"><span class="settings-row-label">Version</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-version">—</span></div>
<div class="settings-row"><span class="settings-row-label">Uptime</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-uptime">—</span></div>
<div class="settings-row"><span class="settings-row-label">Astral</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-astral">—</span></div>
<div class="settings-row"><span class="settings-row-label">Database</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-db">—</span></div>
</div>
<div class="settings-section">
<div class="settings-section-label">HARDWARE</div>
<div class="settings-row"><span class="settings-row-label">Hostname</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-hostname">—</span></div>
<div class="settings-row"><span class="settings-row-label">Kernel</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-kernel">—</span></div>
<div class="settings-row"><span class="settings-row-label">Python</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-python">—</span></div>
<div class="settings-row"><span class="settings-row-label">Hailo</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-hailo">—</span></div>
<div class="settings-row"><span class="settings-row-label">RAM</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-ram">—</span></div>
<div class="settings-row"><span class="settings-row-label">Storage</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-storage">—</span></div>
</div>
<div class="settings-section">
<div class="settings-section-label">NETWORK</div>
<div class="settings-row"><span class="settings-row-label">WiFi (wlan0)</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-ip">—</span></div>
<div class="settings-row"><span class="settings-row-label">Camera (eth0)</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-eth0">—</span></div>
<div class="settings-row"><span class="settings-row-label">Tailscale</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-tailscale">—</span></div>
</div></div></div>
<div id="settings-screen-cpu_temp_graph" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('system')">◀ BACK</button><span class="settings-title">🌡 CPU TEMP HISTORY</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body" style="padding:0;"><div style="display:flex;gap:8px;padding:14px 20px;border-bottom:1px solid rgba(var(--accent-rgb),0.15);"><button class="sensors-range-btn active" id="cputemp-btn-1h" onclick="cpuTempLoad('1h',this)">1H</button><button class="sensors-range-btn" id="cputemp-btn-24h" onclick="cpuTempLoad('24h',this)">24H</button><button class="sensors-range-btn" id="cputemp-btn-7d" onclick="cpuTempLoad('7d',this)">7D</button></div><div style="flex:1;padding:16px;display:flex;flex-direction:column;gap:12px;min-height:0;"><div id="cputemp-sublabel" style="font-size:13px;color:var(--text-sub);font-weight:600;letter-spacing:1px;"></div><div style="flex:1;background:rgba(var(--accent-rgb),0.05);border:1px solid rgba(var(--accent-rgb),0.15);border-radius:10px;padding:12px;min-height:200px;"><canvas id="cputemp-canvas"></canvas><div id="cputemp-nodata" style="display:none;color:#475569;font-size:15px;font-weight:600;text-align:center;padding:40px;">No data for this range</div></div></div></div></div>
<div id="settings-screen-timedate" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('main')">◀ BACK</button><span class="settings-title">🕐 TIME &amp; DATE</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body">
<div class="settings-section">
<div class="settings-section-label">TIME FORMAT</div>
<div class="settings-row"><div><div class="settings-row-label">Clock Format</div><div class="settings-row-sub">Choose 12-hour or 24-hour display</div></div>
<select class="settings-select" id="settings-time-format" onchange="settingsSetTimeFormat(this.value)" style="width:130px;"><option value="24">24 Hour</option><option value="12">12 Hour</option></select></div>
</div>
<div class="settings-section">
<div class="settings-section-label">TIME SOURCE</div>
<div class="settings-row"><div><div class="settings-row-label">Time Source</div><div class="settings-row-sub">Automatic uses NTP network time</div></div>
<select class="settings-select" id="settings-time-source" onchange="settingsSetTimeSource(this.value)" style="width:150px;"><option value="auto">Automatic (NTP)</option><option value="manual">Manual</option></select></div>
<div id="settings-manual-time" style="display:none;">
<div class="settings-row"><div><div class="settings-row-label">Set Date</div></div>
<input type="date" id="settings-manual-date" class="settings-select" style="width:180px;"></div>
<div class="settings-row"><div><div class="settings-row-label">Set Time</div></div>
<input type="time" id="settings-manual-time-input" class="settings-select" style="width:150px;" step="1"></div>
<div class="settings-row"><button class="settings-btn" onclick="settingsApplyManualTime()" style="width:100%;">APPLY</button></div>
</div>
</div>
<div class="settings-section">
<div class="settings-section-label">CURRENT</div>
<div class="settings-row"><span class="settings-row-label">Timezone</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-timezone">—</span></div>
<div class="settings-row"><span class="settings-row-label">Current Time</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-currenttime">—</span></div>
<div class="settings-row"><span class="settings-row-label">NTP Sync</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="si-ntp">—</span></div>
</div>
</div></div>
<div id="settings-screen-network" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('main')">◀ BACK</button><span class="settings-title">📡 NETWORK</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body">
<div class="settings-section">
<div class="settings-section-label">WIFI (wlan0)</div>
<div class="settings-row"><span class="settings-row-label">IP Address</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="net-wlan-ip">—</span></div>
<div class="settings-row"><span class="settings-row-label">SSID</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="net-wlan-ssid">—</span></div>
<div class="settings-row"><span class="settings-row-label">Signal</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="net-wlan-signal">—</span></div>
</div>
<div class="settings-section">
<div class="settings-section-label">CAMERA SUBNET (eth0)</div>
<div class="settings-row"><span class="settings-row-label">IP Address</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="net-eth0-ip">—</span></div>
<div class="settings-row"><span class="settings-row-label">Status</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="net-eth0-status">—</span></div>
</div>
<div class="settings-section">
<div class="settings-section-label">TAILSCALE</div>
<div class="settings-row"><span class="settings-row-label">IP Address</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="net-ts-ip">—</span></div>
<div class="settings-row"><span class="settings-row-label">Status</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="net-ts-status">—</span></div>
</div>
<div class="settings-section">
<div class="settings-section-label">INTERNET</div>
<div class="settings-row"><span class="settings-row-label">Connectivity</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="net-internet">—</span></div>
</div>
<div style="padding-top:8px;"><button class="settings-btn" onclick="settingsRefreshNetwork()" style="width:100%;">REFRESH</button></div>
</div></div>
<div id="settings-screen-system" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('main')">◀ BACK</button><span class="settings-title">💾 SYSTEM</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body">
<div class="settings-section">
<div class="settings-section-label">SYSTEM STATUS</div>
<div class="settings-row"><span class="settings-row-label">Uptime</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="sys-uptime">—</span></div>
<div class="settings-row"><span class="settings-row-label">CPU Temp</span><div style="display:flex;align-items:center;gap:10px;"><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="sys-cputemp">—</span><button class="settings-btn" style="padding:6px 12px;font-size:12px;" onclick="settingsNav('cpu_temp_graph')">📈 HISTORY</button></div></div>
<div class="settings-row"><span class="settings-row-label">Storage</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="sys-storage">—</span></div>
</div>
<div class="settings-section">
<div class="settings-section-label">SERVICES</div>
<div id="sys-services-list" style="display:flex;flex-direction:column;gap:8px;"></div>
</div>
<div class="settings-section">
<div class="settings-section-label">BACKUP &amp; SYNC</div>
<div class="settings-row"><span class="settings-row-label">Last Backup</span><span class="settings-val" style="font-family:Rajdhani,sans-serif;" id="sys-last-backup">—</span></div>
<div style="display:flex;gap:10px;margin-top:8px;">
<button class="settings-btn" onclick="sysBackupNow()" style="flex:1;">BACKUP NOW</button>
<button class="settings-btn" onclick="sysGitPush()" style="flex:1;">PUSH TO GITHUB</button>
</div>
</div>
<div class="settings-section">
<div class="settings-section-label">LOGS</div>
<div style="display:flex;gap:10px;margin-bottom:8px;">
<select class="settings-select" id="sys-log-service" style="flex:2;">
<option value="dashboard-api">dashboard-api</option>
<option value="frigate">Frigate</option>
<option value="rak-reader">rak-reader</option>
<option value="automation-engine">automation-engine</option>
</select>
<select class="settings-select" id="sys-log-lines" style="flex:1;">
<option value="20">20 lines</option>
<option value="50">50 lines</option>
<option value="100">100 lines</option>
</select>
<button class="settings-btn" onclick="sysLoadLogs()">LOAD</button>
</div>
<div id="sys-log-box" style="background:rgba(0,0,0,0.4);border:1px solid rgba(var(--accent-rgb),0.2);border-radius:8px;padding:12px;max-height:300px;overflow-y:auto;font-family:monospace;font-size:11px;color:var(--text-sub);white-space:pre-wrap;word-break:break-all;line-height:1.5;">No logs loaded</div>
</div>
<div class="settings-section">
<div class="settings-section-label">POWER</div>
<div style="display:flex;gap:10px;min-width:0;overflow:hidden;">
<button class="settings-btn" onclick="if(confirm('Close dashboard?'))fetch('/api/exit-kiosk',{method:'POST'})" style="flex:1;min-width:0;padding:14px;background:rgba(220,40,40,0.15);border-color:rgba(220,40,40,0.4);color:#fca5a5;">✕ CLOSE</button>
<button class="settings-btn" onclick="sysReboot()" style="flex:1;min-width:0;padding:14px;">🔄 REBOOT</button>
<button class="settings-btn auto-btn-danger" onclick="sysShutdown()" style="flex:1;min-width:0;padding:14px;background:rgba(220,40,40,0.15);border-color:rgba(220,40,40,0.4);color:#fca5a5;">⏻ SHUTDOWN</button>
</div>
</div>
</div></div>


<div id="settings-screen-devices" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('main')">◀ BACK</button><span class="settings-title">📱 DEVICES</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">✕ CLOSE</button></div><div class="settings-body">
<div class="settings-section">
<div class="settings-section-label">CORE HARDWARE</div>
<div id="dev-hardware-list" style="display:flex;flex-direction:column;gap:8px;"></div>
</div>
<div class="settings-section">
<div class="settings-section-label">REGISTERED DEVICES</div>
<div id="dev-device-list" style="display:flex;flex-direction:column;gap:8px;"></div>
</div>


<div style="padding-top:8px;"><button class="settings-btn" onclick="devRefresh()" style="width:100%;">REFRESH</button></div>
</div></div>
<div id="settings-screen-notifications" class="settings-screen"><div class="settings-header"><button class="settings-btn" onclick="settingsBack('main')">&#9664; BACK</button><span class="settings-title">&#128276; NOTIFICATIONS</span><button class="settings-btn settings-btn-close" onclick="settingsClose()">&#10005; CLOSE</button></div><div class="settings-body">
<div class="settings-section">
<div class="settings-section-label">NOTIFICATION TYPES</div>
<div class="settings-row"><div><div class="settings-row-label">Camera Motion</div><div class="settings-row-sub">Alerts when camera detects motion</div></div>
<label class="settings-toggle"><input type="checkbox" id="notif-camera-motion" onchange="notifSave()"><span class="settings-toggle-slider"></span></label></div>
<div class="settings-row"><div><div class="settings-row-label">System Alerts</div><div class="settings-row-sub">CPU temp, storage warnings</div></div>
<label class="settings-toggle"><input type="checkbox" id="notif-system-alerts" onchange="notifSave()"><span class="settings-toggle-slider"></span></label></div>
<div class="settings-row"><div><div class="settings-row-label">Sensor Alerts</div><div class="settings-row-sub">Threshold alerts from sensors</div></div>
<label class="settings-toggle"><input type="checkbox" id="notif-sensor-alerts" onchange="notifSave()"><span class="settings-toggle-slider"></span></label></div>
<div class="settings-row"><div><div class="settings-row-label">Automation Alerts</div><div class="settings-row-sub">Notifications from automation rules</div></div>
<label class="settings-toggle"><input type="checkbox" id="notif-auto-alerts" onchange="notifSave()"><span class="settings-toggle-slider"></span></label></div>
</div>

<div class="settings-section">
<div class="settings-section-label">SENSOR ALERT THRESHOLDS</div>
<div id="notif-thresholds-list" style="display:flex;flex-direction:column;gap:8px;"></div>
<div style="display:flex;gap:8px;margin-top:8px;">
<select id="notif-thresh-sensor" class="settings-select" style="flex:2;">
<option value="rak_temp">Temperature</option>
<option value="rak_humidity">Humidity</option>
<option value="rak_pressure">Barometric Pressure</option>
<option value="rak_airquality">Air Quality</option>
<option value="rak_dewpoint">Dew Point</option>
</select>
<select id="notif-thresh-op" class="settings-select" style="flex:1;">
<option value="below">Below</option>
<option value="above">Above</option>
</select>
<input type="number" id="notif-thresh-value" class="settings-select" placeholder="Value" style="flex:1;max-width:80px;">
<button class="settings-btn" onclick="notifAddThreshold()">ADD</button>
</div>
</div>

<div class="settings-section">
<div class="settings-section-label">QUIET HOURS</div>
<div class="settings-row"><div><div class="settings-row-label">Start</div><div class="settings-row-sub">Suppress notifications after this time</div></div>
<input type="time" id="notif-quiet-start" class="settings-select" style="width:130px;" onchange="notifSave()"></div>
<div class="settings-row"><div><div class="settings-row-label">End</div><div class="settings-row-sub">Resume notifications at this time</div></div>
<input type="time" id="notif-quiet-end" class="settings-select" style="width:130px;" onchange="notifSave()"></div>
</div>

<div class="settings-section">
<div class="settings-section-label">SOUND</div>
<div class="settings-row"><div><div class="settings-row-label">Audible Alert</div><div class="settings-row-sub">Play sound on kiosk for notifications</div></div>
<label class="settings-toggle"><input type="checkbox" id="notif-sound" onchange="notifSave()"><span class="settings-toggle-slider"></span></label></div>
</div>

<div class="settings-section">
<div class="settings-section-label">NOTIFICATION HISTORY</div>
<div id="notif-history-list" style="display:flex;flex-direction:column;gap:4px;max-height:300px;overflow-y:auto;"></div>
<button class="settings-btn" onclick="notifLoadHistory()" style="width:100%;margin-top:8px;">REFRESH HISTORY</button>
</div>

</div></div>
</div>




<!-- SENSORS SUBMENU -->
<style>
  #sensors-overlay { font-family: 'Rajdhani', sans-serif; color: var(--text); }
  .sensors-header { display:flex; align-items:center; justify-content:space-between; padding:16px 24px; flex-shrink:0; background:rgba(10,20,60,0.7); border-bottom:1px solid rgba(var(--accent-rgb),0.25); }
  .sensors-title { font-size:20px; font-weight:700; letter-spacing:2px; color:var(--text); }
  .sensors-btn { background:rgba(var(--accent-rgb),0.15); border:1px solid rgba(var(--accent-rgb),0.35); color:var(--text); border-radius:8px; padding:8px 18px; font-family:'Rajdhani',sans-serif; font-size:14px; font-weight:700; letter-spacing:1px; cursor:pointer; transition:background 0.2s; }
  .sensors-btn:hover { background:rgba(var(--accent-rgb),0.3); }
  .sensors-btn-close { background:rgba(220,40,40,0.12); border-color:rgba(220,40,40,0.35); color:#fca5a5; }
  .sensors-btn-close:hover { background:rgba(220,40,40,0.28); }
  .sensors-btn-active { background:rgba(var(--accent-rgb),0.4); border-color:rgba(var(--accent-rgb),0.8); }
  .sensors-screen { display:none; flex-direction:column; height:100%; }
  .sensors-screen.active { display:flex; }
  .sensors-empty { padding:60px 40px; text-align:center; color:var(--text-sub); font-size:16px; font-weight:600; letter-spacing:1px; line-height:2; }
  .sensors-empty-icon { font-size:48px; display:block; margin-bottom:16px; opacity:0.4; }
  .sensors-card { display:flex; align-items:center; gap:16px; background:rgba(var(--accent-rgb),0.1); border:1px solid rgba(var(--accent-rgb),0.25); border-radius:10px; padding:16px 20px; cursor:pointer; transition:background 0.2s; }
  .sensors-card:hover { background:rgba(var(--accent-rgb),0.2); }
  .sensors-card-icon { font-size:28px; flex-shrink:0; }
  .sensors-card-info { flex:1; display:flex; flex-direction:column; gap:3px; }
  .sensors-card-name { font-size:16px; font-weight:700; color:var(--text); }
  .sensors-card-source { font-size:12px; color:var(--text-sub); font-weight:600; letter-spacing:1px; text-transform:uppercase; }
  .sensors-card-val { font-family:'Orbitron',monospace; font-size:22px; font-weight:700; color:#1e5aff; text-shadow:0 0 10px rgba(var(--accent-rgb),0.5); }
  .sensors-card-null { font-size:16px; color:#475569; font-style:italic; }
  .sensors-range-bar { display:flex; gap:8px; padding:14px 20px; flex-shrink:0; border-bottom:1px solid rgba(var(--accent-rgb),0.15); }
  .sensors-range-btn { background:rgba(var(--accent-rgb),0.1); border:1px solid rgba(var(--accent-rgb),0.25); color:var(--text-sub); border-radius:6px; padding:6px 14px; font-family:'Rajdhani',sans-serif; font-size:13px; font-weight:700; cursor:pointer; transition:all 0.2s; }
  .sensors-range-btn:hover { background:rgba(var(--accent-rgb),0.2); color:var(--text); }
  .sensors-range-btn.active { background:rgba(var(--accent-rgb),0.35); border-color:rgba(var(--accent-rgb),0.7); color:var(--text); }
  .sensors-graph-area { flex:1; padding:20px; display:flex; flex-direction:column; gap:12px; min-height:0; }
  .sensors-graph-canvas-wrap { flex:1; background:rgba(var(--accent-rgb),0.05); border:1px solid rgba(var(--accent-rgb),0.15); border-radius:10px; padding:12px; min-height:0; }
  .sensors-no-data { display:flex; align-items:center; justify-content:center; height:100%; color:#475569; font-size:15px; font-weight:600; }
  .sensors-graph-label { font-size:13px; color:var(--text-sub); font-weight:600; letter-spacing:1px; }
</style>

<div id="sensors-overlay" style="display:none; position:fixed; inset:0; background:var(--overlay-bg); z-index:1000; flex-direction:column;">
  <div id="sensors-screen-list" class="sensors-screen">
    <div class="sensors-header">
      <span class="sensors-title">🌡 SENSORS</span>
      <button class="sensors-btn sensors-btn-close" onclick="sensorsClose()">✕ CLOSE</button>
    </div>
    <div style="flex:1; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:12px;" id="sensors-card-list"></div>
  </div>
  <div id="sensors-screen-graph" class="sensors-screen">
    <div class="sensors-header">
      <span id="sensors-graph-title" class="sensors-title"></span>
      <div style="display:flex; gap:10px;">
        <button class="sensors-btn" onclick="sensorsBackToList()">◀ BACK</button>
        <button class="sensors-btn sensors-btn-close" onclick="sensorsClose()">✕ CLOSE</button>
      </div>
    </div>
    <div class="sensors-range-bar">
      <button class="sensors-range-btn active" onclick="sensorsSetRange('24h',this)">24H</button>
      <button class="sensors-range-btn" onclick="sensorsSetRange('7d',this)">7D</button>
      <button class="sensors-range-btn" onclick="sensorsSetRange('30d',this)">30D</button>
      <button class="sensors-range-btn" onclick="sensorsSetRange('6m',this)">6M</button>
      <button class="sensors-range-btn" onclick="sensorsSetRange('1y',this)">1Y</button>
    </div>
    <div class="sensors-graph-area">
      <div class="sensors-graph-label" id="sensors-graph-sublabel"></div>
      <div class="sensors-graph-canvas-wrap">
        <canvas id="sensors-graph-canvas"></canvas>
        <div class="sensors-no-data" id="sensors-no-data" style="display:none;">No data for this range</div>
      </div>
    </div>
  </div>
</div>

<script>
const _sensors = { sensors: [], currentSensor: null, currentRange: '24h', chart: null };
const _sensorIcons = { rak_temp:'🌡', rak_humidity:'💧', rak_pressure:'🔵', rak_airquality:'💨' };
function _sensorsScreen(id) {
  document.querySelectorAll('.sensors-screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById('sensors-screen-' + id);
  if (el) el.classList.add('active');
}
async function sensorsOpen() {
  const overlay = document.getElementById('sensors-overlay');
  overlay.style.display = 'flex';
  overlay.style.flexDirection = 'column';
  _sensorsScreen('list');
  try {
    const r = await fetch('/api/sensors');
    const data = await r.json();
    _sensors.sensors = data.sensors || [];
  } catch(e) { _sensors.sensors = []; }
  _sensorsRenderList();
}
function sensorsClose() {
  if(_isMobile()) return _mobileClose();
  if (_sensors.chart) { _sensors.chart.destroy(); _sensors.chart = null; }
  document.getElementById('sensors-overlay').style.display = 'none';
}
function sensorsBackToList() {
  if (_sensors.chart) { _sensors.chart.destroy(); _sensors.chart = null; }
  _sensorsScreen('list');
  _sensorsRenderList();
}
function _sensorsRenderList() {
  const el = document.getElementById('sensors-card-list');
  if (!el) return;
  if (_sensors.sensors.length === 0) {
    el.innerHTML = '<div class="sensors-empty"><span class="sensors-empty-icon">🌡</span>No sensors registered.<br>Sensors will appear here automatically<br>when the RAK station is connected.</div>';
    return;
  }
  el.innerHTML = _sensors.sensors.map((s, i) => {
    const icon = _sensorIcons[s.id] || '📊';
    const hasVal = s.last_value !== null && s.last_value !== undefined;
    const ago = s.last_seen ? _sensorsAgo(s.last_seen) : 'No data';
    return '<div class="sensors-card" onclick="sensorsOpenGraph(' + i + ')">' +
      '<span class="sensors-card-icon">' + icon + '</span>' +
      '<div class="sensors-card-info">' +
        '<div class="sensors-card-name">' + s.name + '</div>' +
        '<div class="sensors-card-source">' + s.source + ' · ' + ago + '</div>' +
      '</div>' +
      (hasVal
        ? '<span class="sensors-card-val">' + s.last_value.toFixed(1) + ' ' + s.unit + '</span>'
        : '<span class="sensors-card-null">No data</span>') +
      '</div>';
  }).join('');
}
function _sensorsAgo(ts) {
  const diff = Math.floor(Date.now()/1000 - ts);
  if (diff < 60) return diff + 's ago';
  if (diff < 3600) return Math.floor(diff/60) + 'm ago';
  if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
  return Math.floor(diff/86400) + 'd ago';
}
</script>

<script>
async function sensorsOpenGraph(idx) {
  _sensors.currentSensor = _sensors.sensors[idx];
  _sensors.currentRange = '24h';
  document.querySelectorAll('.sensors-range-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('.sensors-range-btn').classList.add('active');
  const s = _sensors.currentSensor;
  const icon = _sensorIcons[s.id] || '📊';
  document.getElementById('sensors-graph-title').textContent = icon + ' ' + s.name.toUpperCase();
  _sensorsScreen('graph');
  await _sensorsLoadGraph();
}
function sensorsSetRange(range, btn) {
  _sensors.currentRange = range;
  document.querySelectorAll('.sensors-range-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  _sensorsLoadGraph();
}
async function _sensorsLoadGraph() {
  const s = _sensors.currentSensor;
  if (!s) return;
  const noData = document.getElementById('sensors-no-data');
  const canvas = document.getElementById('sensors-graph-canvas');
  try {
    const r = await fetch('/api/sensors/' + s.id + '/history?range=' + _sensors.currentRange);
    const data = await r.json();
    const points = data.points || [];
    if (points.length === 0) {
      noData.style.display = 'flex';
      canvas.style.display = 'none';
      if (_sensors.chart) { _sensors.chart.destroy(); _sensors.chart = null; }
      document.getElementById('sensors-graph-sublabel').textContent = '';
      return;
    }
    noData.style.display = 'none';
    canvas.style.display = 'block';
    const labels = points.map(p => {
      const d = new Date(p.t * 1000);
      if (_sensors.currentRange === '24h') return d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
      return d.toLocaleDateString([], {month:'short',day:'numeric'});
    });
    const values = points.map(p => p.v);
    const min = Math.min(...values);
    const max = Math.max(...values);
    document.getElementById('sensors-graph-sublabel').textContent =
      s.name + ' · Min: ' + min.toFixed(1) + s.unit + '  Max: ' + max.toFixed(1) + s.unit + '  Latest: ' + values[values.length-1].toFixed(1) + s.unit;
    if (_sensors.chart) { _sensors.chart.destroy(); _sensors.chart = null; }
    const ctx = canvas.getContext('2d');
    _sensors.chart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          data: values,
          borderColor: '#1e5aff',
          backgroundColor: 'rgba(var(--accent-rgb),0.1)',
          borderWidth: 2,
          pointRadius: points.length > 100 ? 0 : 3,
          pointBackgroundColor: '#1e5aff',
          fill: true,
          tension: 0.3
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { color:'var(--text-sub)', maxTicksLimit:8, font:{family:'Rajdhani',size:12} }, grid: { color:'rgba(var(--accent-rgb),0.1)' } },
          y: { ticks: { color:'var(--text-sub)', font:{family:'Orbitron',size:11}, callback: v => v.toFixed(1) + s.unit }, grid: { color:'rgba(var(--accent-rgb),0.1)' } }
        }
      }
    });
  } catch(e) {
    noData.style.display = 'flex';
    canvas.style.display = 'none';
  }
}
</script>
<script src="chart.min.js"></script>
<script src="settings.js?v=21"></script>
<script src="camera.js?v=2"></script>

<script>
(function() {
  var params = new URLSearchParams(window.location.search);
  var mob = params.get('mobile');
  if (mob) {
    document.addEventListener('DOMContentLoaded', function() {
      var nb = document.getElementById('notif-bar');
      if (nb) nb.style.display = 'none';
      var ml = document.getElementById('main-layout');
      if (ml) ml.parentElement.style.display = 'none';
      document.body.style.background = '#0a0e1a';
      setTimeout(function() {
        if (mob === 'cam') camOpen();
        else if (mob === 'light') lightOpen();
        else if (mob === 'ops') opsOpen();
        else if (mob === 'sensors') sensorsOpen();
        else if (mob === 'auto') autoOpen();
        else if (mob === 'settings') settingsOpen();
      }, 500);
    });
  }
})();
</script>

<!-- SCREENSAVER -->
<style>
  #screensaver { position:fixed; inset:0; z-index:9000; background:#000;
    display:none; align-items:center; justify-content:center; }
  #ss-photo { position:absolute; inset:0; background-size:cover;
    background-position:center; background-repeat:no-repeat;
    opacity:0; transition:opacity 1.2s ease; }
  #ss-photo.ss-on { opacity:1; }
  #ss-clock-wrap { position:relative; z-index:1; text-align:center;
    text-shadow:0 2px 30px rgba(0,0,0,0.9); pointer-events:none; }
  #ss-time { font-family:'Orbitron',monospace; font-size:clamp(60px,10vw,130px);
    font-weight:700; color:rgba(255,255,255,0.92); letter-spacing:8px; }
  #ss-date { font-family:'Rajdhani',sans-serif; font-size:clamp(20px,3vw,34px);
    color:rgba(255,255,255,0.55); letter-spacing:4px; margin-top:14px; font-weight:600; }
</style>

<div id="screensaver">
  <div id="ss-photo"></div>
  <div id="ss-clock-wrap">
    <div id="ss-time">00:00:00</div>
    <div id="ss-date"></div>
  </div>
</div>

<script>
const _ss={timer:null,photoTimer:null,photos:[],photoIdx:0,active:false};
function _ssTimeout(){const el=document.getElementById('settings-ss-timeout');const v=el?parseInt(el.value):60;return v===0?null:v*1000;}
function _ssDuration(){const el=document.getElementById('settings-ss-duration');return(el?parseInt(el.value):5)*1000;}
function _ssClockOn(){const el=document.getElementById('settings-ss-clock');return el?el.checked:true;}
function _ssResetTimer(){clearTimeout(_ss.timer);if(_ss.active)return;const t=_ssTimeout();if(t)_ss.timer=setTimeout(_ssActivate,t);}
async function _ssActivate(){
  _ss.active=true;
  const ov=document.getElementById('screensaver');
  ov.style.display='flex';
  document.getElementById('ss-clock-wrap').style.display=_ssClockOn()?'block':'none';
  try{const _alb=localStorage.getItem('dashSsAlbum')||'1';const r=await fetch('/api/photos?album='+_alb);const d=await r.json();_ss.photos=d.photos||[];}catch(e){_ss.photos=[];}
  _ss.photoIdx=0;_ssNextPhoto();_ssTick();
}
function _ssNextPhoto(){
  clearTimeout(_ss.photoTimer);
  const el=document.getElementById('ss-photo');
  if(_ss.photos.length===0){el.classList.remove('ss-on');return;}
  el.classList.remove('ss-on');
  setTimeout(()=>{
    el.style.backgroundImage='url('+_ss.photos[_ss.photoIdx]+')';
    el.classList.add('ss-on');
    _ss.photoIdx=(_ss.photoIdx+1)%_ss.photos.length;
    _ss.photoTimer=setTimeout(_ssNextPhoto,_ssDuration());
  },1200);
}
function _ssDismiss(){
  if(!_ss.active)return;
  _ss.active=false;
  clearTimeout(_ss.photoTimer);clearTimeout(_ss.timer);
  document.getElementById('screensaver').style.display='none';
  document.getElementById('ss-photo').classList.remove('ss-on');
  _ssResetTimer();
}
function _ssTick(){
  if(!_ss.active)return;
  const now=new Date();
  const h=String(now.getHours()).padStart(2,'0');
  const m=String(now.getMinutes()).padStart(2,'0');
  const s=String(now.getSeconds()).padStart(2,'0');
  const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  document.getElementById('ss-time').textContent=h+':'+m+':'+s;
  document.getElementById('ss-date').textContent=days[now.getDay()]+'  ·  '+(now.getMonth()+1)+'/'+now.getDate()+'/'+now.getFullYear();
  setTimeout(_ssTick,1000);
}
['touchstart','mousemove','keydown','click'].forEach(ev=>{
  document.addEventListener(ev,()=>{if(_ss.active)_ssDismiss();else _ssResetTimer();},{passive:true});
});
_ssResetTimer();
</script>

<!-- AUTOMATION SUBMENU -->
<style>
#auto-overlay{font-family:'Rajdhani',sans-serif;color:var(--text);}
.auto-header{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;flex-shrink:0;background:rgba(10,20,60,0.7);border-bottom:1px solid rgba(var(--accent-rgb),0.25);}
.auto-title{font-size:20px;font-weight:700;letter-spacing:2px;color:var(--text);}
.auto-btn{background:rgba(var(--accent-rgb),0.15);border:1px solid rgba(var(--accent-rgb),0.35);color:var(--text);border-radius:8px;padding:8px 18px;font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;letter-spacing:1px;cursor:pointer;transition:background 0.2s;}
.auto-btn:hover{background:rgba(var(--accent-rgb),0.3);}
.auto-btn-close{background:rgba(220,40,40,0.12);border-color:rgba(220,40,40,0.35);color:#fca5a5;}
.auto-btn-close:hover{background:rgba(220,40,40,0.28);}
.auto-btn-danger{background:rgba(220,40,40,0.15);border-color:rgba(220,40,40,0.4);color:#fca5a5;}
.auto-btn-danger:hover{background:rgba(220,40,40,0.3);}
.auto-btn-success{background:rgba(34,197,94,0.15);border-color:rgba(34,197,94,0.4);color:#86efac;}
.auto-btn-success:hover{background:rgba(34,197,94,0.3);}
.auto-screen{display:none;flex-direction:column;height:100%;}
.auto-screen.active{display:flex;}
.auto-rule-item{display:flex;align-items:center;gap:14px;background:rgba(var(--accent-rgb),0.1);border:1px solid rgba(var(--accent-rgb),0.25);border-radius:10px;padding:14px 18px;transition:background 0.2s;}
.auto-rule-item:hover{background:rgba(var(--accent-rgb),0.18);}
.auto-rule-name{font-size:16px;font-weight:700;flex:1;}
.auto-rule-summary{font-size:12px;color:var(--text-sub);font-weight:600;}
.auto-rule-cat{font-size:11px;font-weight:700;letter-spacing:1px;color:var(--accent);background:rgba(var(--accent-rgb),0.15);border:1px solid rgba(var(--accent-rgb),0.3);border-radius:4px;padding:2px 8px;text-transform:uppercase;}
.auto-toggle{position:relative;width:48px;height:24px;cursor:pointer;flex-shrink:0;}
.auto-toggle input{opacity:0;width:0;height:0;}
.auto-toggle-slider{position:absolute;inset:0;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);border-radius:24px;transition:0.3s;}
.auto-toggle-slider:before{content:'';position:absolute;height:18px;width:18px;left:2px;bottom:2px;background:var(--text-sub);border-radius:50%;transition:0.3s;}
.auto-toggle input:checked+.auto-toggle-slider{background:rgba(34,197,94,0.3);border-color:rgba(34,197,94,0.5);}
.auto-toggle input:checked+.auto-toggle-slider:before{transform:translateX(24px);background:#22c55e;box-shadow:0 0 8px rgba(34,197,94,0.7);}
.auto-form-section{background:rgba(var(--accent-rgb),0.08);border:1px solid rgba(var(--accent-rgb),0.2);border-radius:12px;padding:18px 22px;display:flex;flex-direction:column;gap:14px;}
.auto-form-label{font-size:11px;font-weight:700;letter-spacing:2px;color:var(--text-sub);text-transform:uppercase;}
.auto-form-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.auto-select{background:rgba(var(--accent-rgb),0.12);border:1px solid rgba(var(--accent-rgb),0.3);color:var(--text);border-radius:8px;padding:10px 14px;font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:600;cursor:pointer;flex:1;min-width:140px;}
.auto-select option{background:#0a1428;}
.auto-input{background:rgba(var(--accent-rgb),0.12);border:1px solid rgba(var(--accent-rgb),0.3);color:var(--text);border-radius:8px;padding:10px 14px;font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:600;flex:1;min-width:100px;}
.auto-input:focus,.auto-select:focus{outline:none;border-color:var(--accent);}
.auto-action-item{display:flex;align-items:center;gap:10px;background:rgba(var(--accent-rgb),0.06);border:1px solid rgba(var(--accent-rgb),0.15);border-radius:8px;padding:12px 14px;}
.auto-action-remove{background:none;border:1px solid rgba(220,40,40,0.3);border-radius:6px;color:#f87171;font-size:16px;width:32px;height:32px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.auto-action-remove:hover{background:rgba(220,40,40,0.2);}
.auto-day-btn{background:rgba(var(--accent-rgb),0.1);border:1px solid rgba(var(--accent-rgb),0.25);color:var(--text-sub);border-radius:6px;padding:6px 10px;font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:700;cursor:pointer;min-width:38px;text-align:center;}
.auto-day-btn.active{background:rgba(var(--accent-rgb),0.4);border-color:var(--accent);color:var(--text);}
.auto-empty{padding:40px;text-align:center;color:var(--text-sub);font-size:16px;font-weight:600;letter-spacing:1px;}
.auto-cat-group{display:flex;flex-direction:column;gap:8px;margin-bottom:16px;}
.auto-cat-label{font-size:12px;font-weight:700;letter-spacing:2px;color:var(--text-sub);text-transform:uppercase;padding-left:4px;}
</style>

