<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { width: 100vw; height: 100vh; overflow: hidden; background: #0042f9; font-family: 'Rajdhani', sans-serif; display: flex; flex-direction: column; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
</style>
</head>
<body>
<div id="notif" style="background:rgba(0,47,178,0.45);border-bottom:1px solid rgba(30,90,255,0.4);padding:10px 24px;display:flex;gap:32px;align-items:center;font-size:15px;color:#a0b8e8;">
  <div style="display:flex;align-items:center;gap:10px;">
    <div style="width:10px;height:10px;border-radius:50%;background:#1e5aff;animation:pulse 2s infinite;"></div>
    <span><b style="color:#e0e8ff">Front East</b> — Person Detected — 2m ago</span>
  </div>
  <div style="display:flex;align-items:center;gap:10px;">
    <div style="width:10px;height:10px;border-radius:50%;background:#22c55e;"></div>
    <span><b style="color:#e0e8ff">Back West</b> — Vehicle Detected — 16m ago</span>
  </div>
</div>
<div style="display:flex;flex:1;padding:16px 24px;gap:24px;">

  <div style="display:flex;flex-direction:column;gap:14px;width:170px;justify-content:center;">
    <button onclick="" style="background:rgba(30,90,255,0.18);border:1px solid rgba(30,90,255,0.4);border-radius:16px;padding:18px 12px;color:#e0e8ff;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:6px;">
      <span style="font-size:28px;">📷</span><span style="font-size:17px;font-weight:700;">Cameras</span>
    </button>
    <button onclick="" style="background:rgba(30,90,255,0.18);border:1px solid rgba(30,90,255,0.4);border-radius:16px;padding:18px 12px;color:#e0e8ff;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:6px;">
      <span style="font-size:28px;">💡</span><span style="font-size:17px;font-weight:700;">Lighting</span>
    </button>
    <button onclick="" style="background:rgba(30,90,255,0.18);border:1px solid rgba(30,90,255,0.4);border-radius:16px;padding:18px 12px;color:#e0e8ff;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:6px;">
      <span style="font-size:28px;">⚙️</span><span style="font-size:17px;font-weight:700;">Operations</span>
    </button>
    <button onclick="" style="background:rgba(30,90,255,0.18);border:1px solid rgba(30,90,255,0.4);border-radius:16px;padding:18px 12px;color:#e0e8ff;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:6px;">
      <span style="font-size:28px;">🌡</span><span style="font-size:17px;font-weight:700;">Sensors</span>
    </button>
    <button onclick="" style="background:rgba(30,90,255,0.18);border:1px solid rgba(30,90,255,0.4);border-radius:16px;padding:18px 12px;color:#e0e8ff;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:6px;">
      <span style="font-size:28px;">🔧</span><span style="font-size:17px;font-weight:700;">Settings</span>
    </button>
  </div>

  <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;">
    <canvas id="clock" width="480" height="480"></canvas>
    <div id="timetext" style="font-family:'Orbitron',monospace;font-size:52px;font-weight:700;color:#e0e8ff;margin-top:20px;letter-spacing:5px;text-shadow:0 0 18px rgba(30,90,255,0.6);"></div>
    <div id="datetext" style="font-family:'Rajdhani',sans-serif;font-size:22px;color:#8ea4d4;margin-top:6px;letter-spacing:3px;font-weight:600;"></div>
  </div>

  <div style="width:220px;display:flex;flex-direction:column;gap:14px;justify-content:center;">
    <div style="background:rgba(30,90,255,0.14);border:1px solid rgba(30,90,255,0.35);border-radius:16px;padding:16px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(30,90,255,0.18);border-radius:10px;border:1px solid rgba(30,90,255,0.35);">
          <div style="font-size:13px;color:#8ea4d4;text-transform:uppercase;letter-spacing:1px;">Temp</div>
          <div style="font-family:'Orbitron',monospace;font-size:20px;color:#e0e8ff;font-weight:700;">42°F</div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(30,90,255,0.18);border-radius:10px;border:1px solid rgba(30,90,255,0.35);">
          <div style="font-size:13px;color:#8ea4d4;text-transform:uppercase;letter-spacing:1px;">Humid</div>
          <div style="font-family:'Orbitron',monospace;font-size:20px;color:#e0e8ff;font-weight:700;">68%</div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(30,90,255,0.18);border-radius:10px;border:1px solid rgba(30,90,255,0.35);">
          <div style="font-size:13px;color:#8ea4d4;text-transform:uppercase;letter-spacing:1px;">Pres</div>
          <div style="font-family:'Orbitron',monospace;font-size:20px;color:#e0e8ff;font-weight:700;">29.92</div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(30,90,255,0.18);border-radius:10px;border:1px solid rgba(30,90,255,0.35);">
          <div style="font-size:13px;color:#8ea4d4;text-transform:uppercase;letter-spacing:1px;">AQI</div>
          <div style="font-family:'Orbitron',monospace;font-size:20px;color:#e0e8ff;font-weight:700;">Good</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;justify-content:center;margin-top:12px;gap:8px;">
        <span style="font-size:22px;">🌙</span>
        <span style="font-size:16px;color:#8ea4d4;font-weight:600;">Waxing Gibbous</span>
      </div>
    </div>

    <div style="background:rgba(30,90,255,0.14);border:1px solid rgba(30,90,255,0.35);border-radius:16px;padding:16px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;" id="gauges"></div>
    </div>

    <button style="background:rgba(30,90,255,0.18);border:1px solid rgba(30,90,255,0.4);border-radius:16px;padding:22px 12px;color:#e0e8ff;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;">
      <span style="font-size:26px;">⚡</span>
      <span style="font-family:'Rajdhani',sans-serif;font-size:20px;font-weight:700;letter-spacing:1px;">AUTOMATION</span>
    </button>
  </div>
</div>

<script>
function buildGauges(data) {
const canvas = document.getElementById('clock');
const ctx = canvas.getContext('2d');
const C = 480, R = C/2;

function drawClock() {
  const now = new Date();
  const hrs = now.getHours(), mins = now.getMinutes(), secs = now.getSeconds();
  const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

  ctx.clearRect(0,0,C,C);

  ctx.beginPath();
  ctx.arc(R,R,R-4,0,Math.PI*2);
  ctx.fillStyle='#0d0d0d';
  ctx.fill();

  for(let i=0;i<60;i++){
    const ang=(i*6-90)*Math.PI/180;
    const isMaj=i%5===0;
    const len=isMaj?22:11;
    const r1=R-20, r2=r1-len;
    ctx.beginPath();
    ctx.moveTo(R+r1*Math.cos(ang),R+r1*Math.sin(ang));
    ctx.lineTo(R+r2*Math.cos(ang),R+r2*Math.sin(ang));
    ctx.strokeStyle=isMaj?'#1e5aff':'rgba(30,90,255,0.35)';
    ctx.lineWidth=isMaj?3.5:1.5;
    ctx.stroke();
  }

  const nums=[
    {o:12,i:'00',a:0},{o:1,i:13,a:30},{o:2,i:14,a:60},{o:3,i:15,a:90},
    {o:4,i:16,a:120},{o:5,i:17,a:150},{o:6,i:18,a:180},{o:7,i:19,a:210},
    {o:8,i:20,a:240},{o:9,i:21,a:270},{o:10,i:22,a:300},{o:11,i:23,a:330}
  ];
  nums.forEach(n=>{
    const rad=(n.a-90)*Math.PI/180;
    ctx.font='bold 26px Orbitron';
    ctx.fillStyle='#e0e8ff';
    ctx.textAlign='center';
    ctx.textBaseline='middle';
    ctx.fillText(n.o, R+176*Math.cos(rad), R+176*Math.sin(rad));
    ctx.font='400 14px Orbitron';
    ctx.fillStyle='#1e5aff';
    ctx.fillText(n.i, R+128*Math.cos(rad), R+128*Math.sin(rad));
  });

  const hourDeg=((hrs%12)*30+mins*0.5-90)*Math.PI/180;
  const minDeg=(mins*6+secs*0.1-90)*Math.PI/180;
  const secDeg=(secs*6-90)*Math.PI/180;

  ctx.lineCap='round';
  ctx.beginPath();
  ctx.moveTo(R,R);
  ctx.lineTo(R+118*Math.cos(hourDeg),R+118*Math.sin(hourDeg));
  ctx.strokeStyle='#4080ff';
  ctx.lineWidth=8;
  ctx.stroke();

  ctx.beginPath();
  ctx.moveTo(R,R);
  ctx.lineTo(R+160*Math.cos(minDeg),R+160*Math.sin(minDeg));
  ctx.strokeStyle='#4080ff';
  ctx.lineWidth=5;
  ctx.stroke();

  ctx.beginPath();
  ctx.moveTo(R,R);
  ctx.lineTo(R+182*Math.cos(secDeg),R+182*Math.sin(secDeg));
  ctx.strokeStyle='#ef4444';
  ctx.lineWidth=2;
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(R,R,11,0,Math.PI*2);
  ctx.fillStyle='#4080ff';
  ctx.fill();

  const h24=String(hrs).padStart(2,'0');
  const m=String(mins).padStart(2,'0');
  const s=String(secs).padStart(2,'0');
  document.getElementById('timetext').textContent=`${h24}:${m}:${s}`;
  const mo=now.getMonth()+1, d=now.getDate(), y=now.getFullYear();
  document.getElementById('datetext').textContent=`${days[now.getDay()]} · ${mo}/${d}/${y}`;

  requestAnimationFrame(drawClock);
}
drawClock();
</script>
</body>
</html>
