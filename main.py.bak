from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from fastapi.staticfiles import StaticFiles
import psutil, subprocess, json, httpx
import sqlite3, time as _time, uuid, datetime, threading, os
from astral import LocationInfo
from astral.sun import sun
from astral.moon import phase as moon_phase

app = FastAPI()
app.add_middleware(CORSMiddleware,allow_origins=["*"],allow_methods=["*"],allow_headers=["*"])

PHOTOS_DIR = "/home/brifas/dashboard-html/photos"
os.makedirs(PHOTOS_DIR, exist_ok=True)
app.mount("/photos", StaticFiles(directory=PHOTOS_DIR), name="photos")

DB_PATH = "/home/brifas/dashboard.db"
LOCATION = LocationInfo("Tallmansville","WV","America/New_York",38.8376,-80.1284)

def _db():
    return sqlite3.connect(DB_PATH)

@app.on_event("startup")
def init_db():
    conn = _db()
    conn.execute("""CREATE TABLE IF NOT EXISTS device_registry (
        id TEXT PRIMARY KEY, name TEXT, category TEXT DEFAULT 'light',
        type TEXT DEFAULT 'switch', state TEXT DEFAULT 'off',
        brightness INTEGER DEFAULT 100, color TEXT DEFAULT '#ffffff',
        online INTEGER DEFAULT 0, ip TEXT, uptime TEXT, rssi INTEGER,
        summary TEXT, last_seen INTEGER)""")
    conn.commit(); conn.close()

@app.get("/api/health")
def health(): return {"status":"ok"}

@app.get("/api/system")
def system_stats():
    cpu=psutil.cpu_percent(interval=1); ram=psutil.virtual_memory(); disk=psutil.disk_usage("/")
    try:
        t=subprocess.check_output(["vcgencmd","measure_temp"]).decode()
        cpu_temp=float(t.replace("temp=","").replace("'C\n",""))
    except: cpu_temp=0.0
    return {"cpu_percent":cpu,"cpu_temp":cpu_temp,"ram_percent":ram.percent,
            "ram_used_gb":round(ram.used/1024**3,1),"ram_total_gb":round(ram.total/1024**3,1),
            "disk_percent":disk.percent,"disk_used_gb":round(disk.used/1024**3,1),
            "disk_total_gb":round(disk.total/1024**3,1),"cpu_temp_f":round(cpu_temp*9/5+32,1)}

@app.get("/api/sysinfo")
async def sysinfo():
    import os
    try:
        hn=subprocess.check_output(["hostname"]).decode().strip()
        ips=subprocess.check_output(["hostname","-I"]).decode().strip().split()
        ip=next((i for i in ips if i.startswith("192.168.1.")),ips[0] if ips else "unknown")
        eth0=next((i for i in ips if i.startswith("192.168.2.")),"not connected")
        up=subprocess.check_output(["uptime","-p"]).decode().strip()
        try: db_size=round(os.path.getsize("/home/brifas/dashboard.db")/1024/1024,2)
        except: db_size=0
        try: hailo=subprocess.check_output(["cat","/sys/module/hailo_pci/version"]).decode().strip()
        except: hailo="not detected"
        try: kern=subprocess.check_output(["uname","-r"]).decode().strip()
        except: kern="unknown"
        try: py=subprocess.check_output(["python3","--version"]).decode().strip()
        except: py="unknown"
        ram=psutil.virtual_memory()
        disk=psutil.disk_usage("/")
        return {"hostname":hn,"ip":ip,"eth0":eth0,"tailscale":"100.76.61.67","uptime":up,
            "version":"1.0.0","kernel":kern,"python":py,
            "hailo":hailo,"ram_total":str(round(ram.total/1024**3,1))+" GB",
            "storage_total":str(round(disk.total/1024**3,1))+" GB",
            "db_size":str(db_size)+" MB","astral":"active"}
    except: return {"hostname":"pi5-dashboard","ip":"unknown","eth0":"unknown","tailscale":"100.76.61.67","uptime":"unknown",
        "version":"1.0.0","kernel":"unknown","python":"unknown","hailo":"unknown",
        "ram_total":"unknown","storage_total":"unknown","db_size":"unknown","astral":"unknown"}


@app.get("/api/notifications")
async def notifications():
    items=[]
    try:
        r=httpx.get("http://localhost:5000/api/events?limit=5",timeout=3)
        for e in r.json():
            items.append({"type":"camera","icon":"📷","source":e.get("camera","camera"),
                "message":e.get("label","motion")+" detected","time":e.get("start_time",0)})
    except: pass
    try:
        cpu_temp=0.0
        try:
            t2=subprocess.check_output(["vcgencmd","measure_temp"]).decode()
            cpu_temp=float(t2.replace("temp=","").replace("'C\n","").strip().rstrip("'C"))
        except: pass
        cpu_f=cpu_temp*9/5+32
        if cpu_f>160: items.append({"type":"system","icon":"🔥","source":"System","message":f"CPU temp {cpu_f:.0f}°F","time":__import__("time").time()})
        disk=psutil.disk_usage("/")
        if disk.percent>90: items.append({"type":"system","icon":"💾","source":"System","message":f"Storage {disk.percent}% full","time":__import__("time").time()})
    except: pass
    items.sort(key=lambda x:x.get("time",0),reverse=True)
    return items[:5]


from fastapi import UploadFile, File, Query

@app.post("/api/upload")
async def upload_file(file: UploadFile = File(...), dest: str = Query("photos")):
    import os
    folders = {
        "photos": "/home/brifas/dashboard-html/photos/",
        "themes": "/home/brifas/dashboard-html/static/themes/"
    }
    folder = folders.get(dest)
    if not folder: return {"error": "invalid destination"}
    os.makedirs(folder, exist_ok=True)
    path = os.path.join(folder, file.filename)
    with open(path, "wb") as f2:
        f2.write(await file.read())
    return {"success": True, "path": path}

@app.post("/api/brightness")
async def set_brightness(payload:dict):
    val=int(payload.get("value",80)); subprocess.Popen(["ddcutil","setvcp","10",str(val)])
    return {"success":True,"value":val}

@app.post("/api/display")
async def set_display(payload:dict):
    subprocess.Popen(["vcgencmd","display_power","1" if payload.get("state")=="on" else "0"])
    return {"success":True}

@app.post("/api/exit-kiosk")
def exit_kiosk(): subprocess.Popen(["pkill","chromium"]); return {"status":"exiting"}

@app.get("/api/photos")
def get_photos():
    try:
        exts={".jpg",".jpeg",".png",".gif",".webp"}
        files=sorted([f for f in os.listdir(PHOTOS_DIR) if os.path.splitext(f)[1].lower() in exts])
        return {"photos":[f"/photos/{f}" for f in files]}
    except Exception as e: return {"photos":[],"error":str(e)}

@app.get("/api/solar")
def get_solar():
    try:
        today=datetime.date.today(); s=sun(LOCATION.observer,date=today,tzinfo=LOCATION.timezone)
        mp=moon_phase(today)
        names=["New Moon","Waxing Crescent","First Quarter","Waxing Gibbous","Full Moon","Waning Gibbous","Last Quarter","Waning Crescent"]
        icons=["🌑","🌒","🌓","🌔","🌕","🌖","🌗","🌘"]
        thresholds=[1,7,8,14,15,21,22,29]
        idx=next((i for i,t in enumerate(thresholds) if mp<t),7)
        return {"sunrise":s["sunrise"].strftime("%H:%M"),"sunset":s["sunset"].strftime("%H:%M"),
                "dawn":s["dawn"].strftime("%H:%M"),"dusk":s["dusk"].strftime("%H:%M"),
                "solar_noon":s["noon"].strftime("%H:%M"),"moon_phase":round(mp,1),
                "moon_phase_name":names[idx],"moon_icon":icons[idx]}
    except Exception as e: return {"error":str(e)}

@app.get("/api/events")
async def get_events():
    try:
        async with httpx.AsyncClient() as c:
            r=await c.get("http://localhost:5000/api/events?limit=5",timeout=3)
            return [{"camera":e.get("camera",""),"label":e.get("label",""),
                     "score":round(e.get("score",0)*100),"time":e.get("start_time",0)} for e in r.json()]
    except: return []

@app.get("/api/cameras")
async def get_cameras():
    try:
        async with httpx.AsyncClient() as c:
            cfg=(await c.get("http://localhost:5000/api/config",timeout=5)).json()
            stats=(await c.get("http://localhost:5000/api/stats",timeout=5)).json()
            cam_stats=stats.get("cameras",{})
            return {"cameras":[{"name":n,"online":cam_stats.get(n,{}).get("camera_fps",0)>0}
                                for n in cfg.get("cameras",{}).keys()]}
    except Exception as e: return {"cameras":[],"error":str(e)}

@app.get("/api/clips")
async def get_clips(camera:str=None,label:str=None,limit:int=100):
    try:
        async with httpx.AsyncClient() as c:
            url=f"http://localhost:5000/api/events?limit={limit}&has_clip=1&include_thumbnails=1"
            if camera and camera!="all": url+=f"&camera={camera}"
            if label and label!="all": url+=f"&label={label}"
            clips=[]
            for e in (await c.get(url,timeout=10)).json():
                start=e.get("start_time",0); end=e.get("end_time") or start
                dur=round(end-start) if end>start else 0
                clips.append({"id":e["id"],"camera":e["camera"],"label":e.get("label","unknown"),
                    "score":round((e.get("top_score") or 0)*100),"start_time":start,
                    "duration":f"{dur//60:02d}:{dur%60:02d}",
                    "thumbnail":f"http://localhost:5000/api/events/{e['id']}/thumbnail.jpg",
                    "clip_url":f"http://localhost:5000/api/events/{e['id']}/clip.mp4"})
            return {"clips":clips}
    except Exception as e: return {"clips":[],"error":str(e)}

@app.delete("/api/clips/{event_id}")
async def delete_clip(event_id:str):
    try:
        async with httpx.AsyncClient() as c:
            r=await c.delete(f"http://localhost:5000/api/events/{event_id}",timeout=5)
            return {"success":r.status_code==200}
    except Exception as e: return {"success":False,"error":str(e)}

@app.get("/api/sensors")
def get_sensors():
    try:
        conn=_db(); rows=conn.execute("SELECT id,name,unit,source,last_seen,last_value FROM sensor_registry").fetchall(); conn.close()
        return {"sensors":[{"id":r[0],"name":r[1],"unit":r[2],"source":r[3],"last_seen":r[4],"last_value":r[5]} for r in rows]}
    except Exception as e: return {"sensors":[],"error":str(e)}

@app.get("/api/sensors/{sensor_id}/history")
def get_sensor_history(sensor_id:str,range:str="24h"):
    try:
        since=int(_time.time())-{"24h":86400,"7d":604800,"30d":2592000,"6m":15552000,"1y":31536000}.get(range,86400)
        conn=_db(); rows=conn.execute("SELECT timestamp,value FROM sensor_readings WHERE sensor_id=? AND timestamp>? ORDER BY timestamp ASC",(sensor_id,since)).fetchall(); conn.close()
        return {"sensor_id":sensor_id,"range":range,"points":[{"t":r[0],"v":r[1]} for r in rows]}
    except Exception as e: return {"points":[],"error":str(e)}

@app.post("/api/sensors/ingest")
def ingest_sensor(payload:dict):
    try:
        now=int(_time.time()); conn=_db()
        for rd in payload.get("readings",[]):
            conn.execute("INSERT INTO sensor_readings (timestamp,sensor_id,sensor_name,value,unit) VALUES (?,?,?,?,?)",(now,rd["id"],rd.get("name",""),rd["value"],rd.get("unit","")))
            conn.execute("UPDATE sensor_registry SET last_seen=?,last_value=? WHERE id=?",(now,rd["value"],rd["id"]))
        conn.commit(); conn.close(); return {"success":True}
    except Exception as e: return {"success":False,"error":str(e)}

def _mqtt_publish(topic,payload):
    try:
        import paho.mqtt.publish as pub
        pub.single(topic,payload,hostname="localhost",port=1883)
    except: pass

@app.get("/api/lights")
def get_lights():
    try:
        conn=_db(); rows=conn.execute("SELECT id,name,type,state,brightness,color,last_seen FROM device_registry WHERE category='light'").fetchall(); conn.close()
        return {"devices":[{"id":r[0],"name":r[1],"type":r[2],"state":r[3] or "off","brightness":r[4] if r[4] is not None else 100,"color":r[5] or "#ffffff","last_seen":r[6]} for r in rows]}
    except Exception as e: return {"devices":[],"error":str(e)}

@app.post("/api/lights/{device_id}/control")
async def control_light(device_id:str,command:dict):
    try:
        conn=_db(); a=command.get("action"); v=command.get("value")
        if a=="state": conn.execute("UPDATE device_registry SET state=? WHERE id=?",(v,device_id))
        elif a=="brightness": conn.execute("UPDATE device_registry SET brightness=? WHERE id=?",(v,device_id))
        elif a=="color": conn.execute("UPDATE device_registry SET color=? WHERE id=?",(v,device_id))
        conn.commit(); conn.close()
        _mqtt_publish(f"dashboard/lights/{device_id}/set",json.dumps(command))
        return {"success":True}
    except Exception as e: return {"success":False,"error":str(e)}

@app.get("/api/systems")
def get_systems():
    try:
        conn=_db(); rows=conn.execute("SELECT id,name,type,online,ip,uptime,rssi,summary,last_seen FROM device_registry WHERE category='system'").fetchall(); conn.close()
        return {"systems":[{"id":r[0],"name":r[1],"type":r[2],"online":bool(r[3]),"ip":r[4],"uptime":r[5],"rssi":r[6],"summary":r[7],"last_seen":r[8],"sensors":[],"controls":[],"events":[]} for r in rows]}
    except Exception as e: return {"systems":[],"error":str(e)}

@app.post("/api/systems/{system_id}/control")
async def control_system(system_id:str,command:dict):
    try: _mqtt_publish(f"dashboard/systems/{system_id}/set",json.dumps(command)); return {"success":True}
    except Exception as e: return {"success":False,"error":str(e)}

@app.post("/api/devices/register")
def register_device(device:dict):
    try:
        now=int(_time.time()); conn=_db()
        conn.execute("""INSERT INTO device_registry (id,name,category,type,state,brightness,color,online,ip,last_seen,summary)
            VALUES (?,?,?,?,?,?,?,?,?,?,?)
            ON CONFLICT(id) DO UPDATE SET name=excluded.name,online=1,last_seen=excluded.last_seen,ip=excluded.ip""",
            (device["id"],device["name"],device.get("category","light"),device.get("type","switch"),
             device.get("state","off"),device.get("brightness",100),device.get("color","#ffffff"),
             1,device.get("ip",""),now,device.get("summary","")))
        conn.commit(); conn.close(); return {"success":True}
    except Exception as e: return {"success":False,"error":str(e)}

@app.get("/api/automation/rules")
def get_rules():
    try:
        conn=_db(); rows=conn.execute("SELECT id,name,category,enabled,trigger_type,trigger_config,conditions,actions,last_triggered FROM automation_rules ORDER BY category,name").fetchall(); conn.close()
        return {"rules":[{"id":r[0],"name":r[1],"category":r[2],"enabled":r[3],"trigger_type":r[4],
            "trigger_config":json.loads(r[5] or "{}"),"conditions":json.loads(r[6] or "[]"),
            "actions":json.loads(r[7] or "[]"),"last_triggered":r[8]} for r in rows]}
    except Exception as e: return {"rules":[],"error":str(e)}

@app.post("/api/automation/rules")
def create_rule(rule:dict):
    try:
        rid=str(uuid.uuid4())[:8]; now=int(_time.time()); conn=_db()
        conn.execute("INSERT INTO automation_rules (id,name,category,enabled,trigger_type,trigger_config,conditions,actions,created) VALUES (?,?,?,?,?,?,?,?,?)",
            (rid,rule["name"],rule.get("category","general"),rule.get("enabled",1),rule["trigger_type"],
             json.dumps(rule.get("trigger_config",{})),json.dumps(rule.get("conditions",[])),json.dumps(rule.get("actions",[])),now))
        conn.commit(); conn.close(); return {"success":True,"id":rid}
    except Exception as e: return {"success":False,"error":str(e)}

@app.put("/api/automation/rules/{rule_id}")
def update_rule(rule_id:str,rule:dict):
    try:
        conn=_db()
        conn.execute("UPDATE automation_rules SET name=?,category=?,enabled=?,trigger_type=?,trigger_config=?,conditions=?,actions=? WHERE id=?",
            (rule["name"],rule.get("category","general"),rule.get("enabled",1),rule["trigger_type"],
             json.dumps(rule.get("trigger_config",{})),json.dumps(rule.get("conditions",[])),json.dumps(rule.get("actions",[])),rule_id))
        conn.commit(); conn.close(); return {"success":True}
    except Exception as e: return {"success":False,"error":str(e)}

@app.delete("/api/automation/rules/{rule_id}")
def delete_rule(rule_id:str):
    try:
        conn=_db(); conn.execute("DELETE FROM automation_rules WHERE id=?",(rule_id,)); conn.commit(); conn.close()
        return {"success":True}
    except Exception as e: return {"success":False,"error":str(e)}

@app.post("/api/automation/rules/{rule_id}/toggle")
def toggle_rule(rule_id:str):
    try:
        conn=_db(); row=conn.execute("SELECT enabled FROM automation_rules WHERE id=?",(rule_id,)).fetchone()
        if not row: return {"success":False,"error":"Not found"}
        new=0 if row[0] else 1
        conn.execute("UPDATE automation_rules SET enabled=? WHERE id=?",(new,rule_id))
        conn.commit(); conn.close(); return {"success":True,"enabled":new}
    except Exception as e: return {"success":False,"error":str(e)}

@app.post("/api/automation/rules/{rule_id}/trigger")
async def manual_trigger(rule_id:str):
    try:
        conn=_db(); row=conn.execute("SELECT actions FROM automation_rules WHERE id=?",(rule_id,)).fetchone(); conn.close()
        if not row: return {"success":False,"error":"Not found"}
        async with httpx.AsyncClient() as c:
            for a in json.loads(row[0] or "[]"):
                if a.get("type")=="light_control":
                    await c.post(f"http://localhost:8000/api/lights/{a['device_id']}/control",json=a.get("command",{}),timeout=5)
                elif a.get("type")=="system_control":
                    await c.post(f"http://localhost:8000/api/systems/{a['system_id']}/control",json=a.get("command",{}),timeout=5)
        return {"success":True}
    except Exception as e: return {"success":False,"error":str(e)}

@app.get("/api/automation/log")
def get_automation_log(limit:int=50):
    try:
        conn=_db(); rows=conn.execute("SELECT timestamp,rule_name,result,detail FROM automation_log ORDER BY timestamp DESC LIMIT ?",(limit,)).fetchall(); conn.close()
        return {"log":[{"timestamp":r[0],"rule_name":r[1],"result":r[2],"detail":r[3]} for r in rows]}
    except Exception as e: return {"log":[],"error":str(e)}

def _mqtt_subscriber():
    try:
        import paho.mqtt.client as mqtt
        def on_connect(client,userdata,flags,rc):
            client.subscribe("dashboard/lights/+/status")
            client.subscribe("dashboard/systems/+/status")
            client.subscribe("dashboard/devices/+/register")
        def on_message(client,userdata,msg):
            try:
                parts=msg.topic.split("/"); payload=json.loads(msg.payload.decode())
                device_id=parts[2]; now=int(_time.time()); conn=_db()
                if parts[3]=="register":
                    conn.execute("""INSERT INTO device_registry (id,name,category,type,state,online,ip,last_seen,summary)
                        VALUES (?,?,?,?,?,?,?,?,?)
                        ON CONFLICT(id) DO UPDATE SET name=excluded.name,online=1,last_seen=excluded.last_seen,ip=excluded.ip""",
                        (device_id,payload.get("name",device_id),payload.get("category","light"),
                         payload.get("type","switch"),payload.get("state","off"),1,
                         payload.get("ip",""),now,payload.get("summary","")))
                else:
                    if "state" in payload: conn.execute("UPDATE device_registry SET state=?,online=1,last_seen=? WHERE id=?",(payload["state"],now,device_id))
                    if "brightness" in payload: conn.execute("UPDATE device_registry SET brightness=? WHERE id=?",(payload["brightness"],device_id))
                    if "color" in payload: conn.execute("UPDATE device_registry SET color=? WHERE id=?",(payload["color"],device_id))
                conn.commit(); conn.close()
            except: pass
        client=mqtt.Client(); client.on_connect=on_connect; client.on_message=on_message
        client.connect("localhost",1883,60); client.loop_forever()
    except: pass

threading.Thread(target=_mqtt_subscriber,daemon=True).start()

app.mount("/", StaticFiles(directory="/home/brifas/dashboard-html", html=True), name="dashboard")
