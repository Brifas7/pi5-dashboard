<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Upload</title>
<style>
body { background:#051c35; color:#e0e8ff; font-family:'Rajdhani',sans-serif; padding:20px; }
h2 { text-align:center; }
.box { background:rgba(30,90,255,0.12); border:1px solid rgba(30,90,255,0.3); border-radius:12px; padding:20px; max-width:400px; margin:20px auto; }
select,input[type=file] { width:100%; padding:10px; margin:10px 0; background:rgba(30,90,255,0.1); border:1px solid rgba(30,90,255,0.3); color:#e0e8ff; border-radius:8px; font-size:16px; }
button { width:100%; padding:14px; background:#1e5aff; border:none; color:white; border-radius:8px; font-size:18px; font-weight:700; cursor:pointer; margin-top:10px; }
button:disabled { opacity:0.5; }
.msg { text-align:center; padding:10px; margin-top:10px; border-radius:8px; }
.ok { background:rgba(34,197,94,0.2); color:#86efac; }
.err { background:rgba(239,68,68,0.2); color:#fca5a5; }
</style>
</head>
<body>
<h2>Upload Files</h2>
<div class="box">
  <label>Destination:</label>
  <select id="dest" onchange="onDestChange()">
    <option value="photos">Screensaver Photos</option>
    <option value="themes">Theme Backgrounds</option>
    <option value="clocks">Clock Face</option>
  </select>
  <label id="theme-label" style="display:none;">For Theme:</label>
  <select id="theme" style="display:none;">
    <option value="">— Pick a theme —</option>
    <option value="water">Water</option>
    <option value="emerald">Emerald</option>
    <option value="titanium">Titanium</option>
    <option value="purple">Electric Purple</option>
    <option value="nebula">Nebula</option>
    <option value="void">Void</option>
    <option value="matrix">Matrix</option>
    <option value="aquatic">Aquatic</option>
    <option value="christmas">Christmas</option>
    <option value="stpatricks">St Patrick's</option>
    <option value="mothersday">Mother's Day</option>
    <option value="july4">July 4th</option>
    <option value="gadsden">Gadsden</option>
    <option value="flagday">Flag Day</option>
    <option value="laborday">Labor Day</option>
    <option value="veteransday">Veterans Day</option>
    <option value="memorialday">Memorial Day</option>
    <option value="womensday">Women's Day</option>
    <option value="soviet">Soviet</option>
    <option value="easter">Easter</option>
    <option value="valentine">Valentine</option>
    <option value="newyears">New Year's</option>
    <option value="thanksgiving">Thanksgiving</option>
    <option value="halloween">Halloween</option>
  </select>
  <label id="album-label">Album:</label>
  <select id="album">
    <option value="1">Album 1</option>
    <option value="2">Album 2</option>
    <option value="3">Album 3</option>
    <option value="4">Album 4</option>
    <option value="5">Album 5</option>
  </select>
  <input type="file" id="file" accept="image/*" multiple onchange="onFilePicked()">
  <div id="preview-area" style="display:none;text-align:center;margin:16px 0;">
    <div style="font-size:14px;color:#8ea4d4;margin-bottom:8px;">Preview (will be cropped to circle):</div>
    <canvas id="preview-canvas" width="260" height="260" style="border:1px solid rgba(30,90,255,0.3);border-radius:50%;background:#0d0d0d;"></canvas>
    <div style="margin-top:12px;display:flex;gap:10px;">
      <button onclick="doUpload()" id="btn-use" style="background:#22c55e;">Use This</button>
      <button onclick="cancelPreview()" id="btn-cancel" style="background:rgba(220,40,40,0.4);">Cancel</button>
    </div>
  </div>
  <button onclick="doUpload()" id="btn">Upload</button>
  <div id="msg"></div>
</div>
<script>
function onDestChange(){
  var dest=document.getElementById('dest').value;
  var showAlbum=(dest==='photos');
  var showTheme=(dest==='themes'||dest==='clocks');
  document.getElementById('album-label').style.display=showAlbum?'block':'none';
  document.getElementById('album').style.display=showAlbum?'block':'none';
  document.getElementById('theme-label').style.display=showTheme?'block':'none';
  document.getElementById('theme').style.display=showTheme?'block':'none';
  cancelPreview();
}
function toggleAlbum(){ onDestChange(); }
function onFilePicked(){
  var dest=document.getElementById('dest').value;
  var files=document.getElementById('file').files;
  if(dest!=='clocks' || !files.length){
    document.getElementById('preview-area').style.display='none';
    document.getElementById('btn').style.display='block';
    return;
  }
  // Clock face: render circular preview of first file
  var f=files[0];
  var reader=new FileReader();
  reader.onload=function(e){
    var img=new Image();
    img.onload=function(){
      var canvas=document.getElementById('preview-canvas');
      var ctx=canvas.getContext('2d');
      ctx.clearRect(0,0,260,260);
      // mimic server-side crop: square crop from center, scale to 260x260
      var w=img.naturalWidth, h=img.naturalHeight;
      var side=Math.min(w,h);
      var sx=(w-side)/2, sy=(h-side)/2;
      ctx.save();
      ctx.beginPath();
      ctx.arc(130,130,130,0,Math.PI*2);
      ctx.clip();
      ctx.drawImage(img, sx,sy,side,side, 0,0,260,260);
      ctx.restore();
      document.getElementById('preview-area').style.display='block';
      document.getElementById('btn').style.display='none';
    };
    img.src=e.target.result;
  };
  reader.readAsDataURL(f);
}
function cancelPreview(){
  document.getElementById('preview-area').style.display='none';
  document.getElementById('btn').style.display='block';
  document.getElementById('file').value='';
}
(function(){
  var params=new URLSearchParams(window.location.search);
  var alb=params.get('album');
  if(alb && ['1','2','3','4','5'].indexOf(alb)>=0){
    document.getElementById('album').value=alb;
  }
  var destParam=params.get('dest');
  if(destParam && ['photos','themes','clocks'].indexOf(destParam)>=0){
    document.getElementById('dest').value=destParam;
  }
  onDestChange();
})();
async function doUpload(){
  var files=document.getElementById('file').files;
  var dest=document.getElementById('dest').value;
  var msg=document.getElementById('msg');
  var btn=document.getElementById('btn');
  if(!files.length){msg.className='msg err';msg.textContent='Pick a file first';return;}
  btn.disabled=true;btn.textContent='Uploading...';
  var ok=0,fail=0;
  for(var i=0;i<files.length;i++){
    var fd=new FormData();
    var fileToSend=files[i];
    // If themes or clocks, rename based on selected theme
    if(dest==='themes'||dest==='clocks'){
      var theme=document.getElementById('theme').value;
      if(!theme){msg.className='msg err';msg.textContent='Pick a theme first';btn.disabled=false;btn.textContent='Upload';return;}
      var ext=files[i].name.split('.').pop().toLowerCase();
      var newName=(dest==='themes')?(theme+'.'+ext):(theme+'_clock.'+ext);
      fileToSend=new File([files[i]],newName,{type:files[i].type});
    }
    fd.append('file',fileToSend);
    try{
      var album=document.getElementById('album').value;var url='/api/upload?dest='+dest+(dest==='photos'?'&album='+album:'');var r=await fetch(url,{method:'POST',body:fd});
      var d=await r.json();
      if(d.success)ok++;else fail++;
    }catch(e){fail++;}
  }
  btn.disabled=false;btn.textContent='Upload';
  msg.className='msg '+(fail?'err':'ok');
  msg.textContent=ok+' uploaded'+(fail?', '+fail+' failed':'');
}
</script>
</body>
</html>
