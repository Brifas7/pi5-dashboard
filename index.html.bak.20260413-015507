<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard</title>
<meta name="viewport" content="width=1920">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--accent-rgb:30,90,255;--accent:#1e5aff;--bg:#051c35;--text:#e0e8ff;--text-sub:#8ea4d4;--notif-bg:rgba(0,47,178,0.45);--overlay-bg:rgba(4,10,35,0.97);}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { width: 100vw; height: 100vh; overflow: hidden; font-family: 'Rajdhani', sans-serif; display: flex; flex-direction: column; background: none; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
#exit-zone { position: fixed; top: 0; right: 0; width: 60px; height: 60px; z-index: 9999; cursor: pointer; }


</style>
</head>
<body>



<div id="exit-zone" title=""></div>

<div style="position:relative;z-index:1;display:flex;flex-direction:column;width:100%;height:100%;">

  <div id="notif-bar" style="background:var(--notif-bg);border-bottom:1px solid rgba(var(--accent-rgb),0.4);padding:18px 28px;display:flex;gap:36px;align-items:center;font-size:16px;color:#a0b8e8;min-height:70px;">
    <span style="color:var(--text-sub);">Loading events...</span>
  </div>

  <div id="main-layout" style="display:flex;flex:1;padding:20px 28px;gap:28px;min-height:0;">

    <div id="nav-col" style="display:flex;flex-direction:column;gap:14px;width:319px;flex-shrink:0;">
      <button onclick="camOpen()" style="background:rgba(var(--accent-rgb),0.18);border:1px solid rgba(var(--accent-rgb),0.4);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">📷</span><span style="font-size:26px;font-weight:700;">Cameras</span>
      </button>
      <button onclick="lightOpen()" style="background:rgba(var(--accent-rgb),0.18);border:1px solid rgba(var(--accent-rgb),0.4);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">💡</span><span style="font-size:26px;font-weight:700;">Lighting</span>
      </button>
      <button onclick="opsOpen()" style="background:rgba(var(--accent-rgb),0.18);border:1px solid rgba(var(--accent-rgb),0.4);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">⚙️</span><span style="font-size:26px;font-weight:700;">Operations</span>
      </button>
      <button onclick="sensorsOpen()" style="background:rgba(var(--accent-rgb),0.18);border:1px solid rgba(var(--accent-rgb),0.4);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">🌡</span><span style="font-size:26px;font-weight:700;">Sensors</span>
      </button>
      <button onclick="settingsOpen()" style="background:rgba(var(--accent-rgb),0.18);border:1px solid rgba(var(--accent-rgb),0.4);border-radius:16px;padding:20px 12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;">
        <span style="font-size:44px;">🔧</span><span style="font-size:26px;font-weight:700;">Settings</span>
      </button>
    </div>

    <div id="clock-col" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:0;">
      <canvas id="clock" width="660" height="660"></canvas>
      <div id="timetext" style="font-family:'Orbitron',monospace;font-size:58px;font-weight:700;color:var(--text);margin-top:18px;letter-spacing:5px;text-shadow:0 0 18px rgba(var(--accent-rgb),0.6);"></div>
      <div id="datetext" style="font-family:'Rajdhani',sans-serif;font-size:24px;color:var(--text-sub);margin-top:6px;letter-spacing:3px;font-weight:600;"></div>
    </div>

    <div id="right-col" style="display:flex;flex-direction:column;gap:14px;width:406px;flex-shrink:0;">
      <div style="background:rgba(var(--accent-rgb),0.14);border:1px solid rgba(var(--accent-rgb),0.35);border-radius:16px;padding:18px;">
        <div style="display:flex;flex-direction:column;align-items:center;padding:14px 8px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);margin-bottom:12px;">
          <div style="font-size:16px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Temperature</div>
          <div id="w-temp" style="font-family:'Orbitron',monospace;font-size:40px;color:var(--text);font-weight:700;">--</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);">
            <div style="font-size:14px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Humidity</div>
            <div id="w-humid" style="font-family:'Orbitron',monospace;font-size:26px;color:var(--text);font-weight:700;">--</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);">
            <div style="font-size:14px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Barometric</div>
            <div id="w-pres" style="font-family:'Orbitron',monospace;font-size:26px;color:var(--text);font-weight:700;">--</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);">
            <div style="font-size:14px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Air Quality</div>
            <div id="w-aqi" style="font-family:'Orbitron',monospace;font-size:26px;color:var(--text);font-weight:700;">--</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:rgba(var(--accent-rgb),0.18);border-radius:10px;border:1px solid rgba(var(--accent-rgb),0.35);">
            <div style="font-size:14px;color:var(--text-sub);text-transform:uppercase;letter-spacing:1px;">Dew Point</div>
            <div id="w-dewpoint" style="font-family:'Orbitron',monospace;font-size:26px;color:var(--text);font-weight:700;">--</div>
          </div>
        </div>
        <div style="display:flex;align-items:center;justify-content:center;margin-top:14px;gap:8px;">
          <span id="moon-phase" style="font-size:17px;color:var(--text-sub);font-weight:600;">--</span>
        </div>
      </div>

      <div style="background:rgba(var(--accent-rgb),0.14);border:1px solid rgba(var(--accent-rgb),0.35);border-radius:16px;padding:18px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;" id="gauges"></div>
      </div>

      <div style="flex:1;"></div>

      <button onclick="autoOpen()" style="background:rgba(var(--accent-rgb),0.18);border:1px solid rgba(var(--accent-rgb),0.4);border-radius:16px;padding:26px 12px;color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:12px;width:100%;">
        <span style="font-size:28px;">⚡</span>
        <span style="font-family:'Rajdhani',sans-serif;font-size:22px;font-weight:700;letter-spacing:1px;">AUTOMATION</span>
      </button>
    </div>

  </div>
</div>

<script>
const _HOST=window.location.hostname;
const _GO2RTC="http://"+_HOST+":1984";
const _FRIGATE="http://"+_HOST+":5000";
let tapCount = 0;
let tapTimer = null;
document.getElementById('exit-zone').addEventListener('click', function() {
  tapCount++;
  if(tapCount === 1) {
    tapTimer = setTimeout(() => { tapCount = 0; }, 3000);
  }
  if(tapCount >= 3) {
    clearTimeout(tapTimer);
    tapCount = 0;
    fetch('/api/exit-kiosk', {method:'POST'});
  }
});

function timeAgo(ts) {
  const diff = Math.floor(Date.now()/1000 - ts);
  if(diff < 60) return diff + 's ago';
  if(diff < 3600) return Math.floor(diff/60) + 'm ago';
  if(diff < 86400) return Math.floor(diff/3600) + 'h ago';
  return Math.floor(diff/86400) + 'd ago';
}

function capitalize(s) {
  return s.charAt(0).toUpperCase() + s.slice(1);
}

function camName(s) {
  return s.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
}

async function fetchEvents() {
  try {
    const res = await fetch('/api/notifications');
    const events = await res.json();
    const bar = document.getElementById('notif-bar');
    if(!events || events.length === 0) {
      bar.innerHTML = '<span style="color:var(--text-sub);">No recent events</span>';
      return;
    }
    bar.innerHTML = events.map(e => `
      <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
        <div style="width:12px;height:12px;border-radius:50%;background:var(--accent);animation:pulse 2s infinite;flex-shrink:0;"></div>
        <span><b style="color:var(--text)">${e.icon} ${e.source}</b> — ${e.message} — ${timeAgo(e.time)}</span>
      </div>
    `).join('');
  } catch(err) {
    console.log('Events fetch failed:', err);
  }
}

function buildGauges(data) {
  const gaugeData = [
    {label:'CPU', value:Math.round(data.cpu_percent)},
    {label:'Pi Temp', value:Math.round(data.cpu_temp_f), max:200, suffix:'°F'},
    {label:'RAM', value:Math.round(data.ram_percent)},
    {label:'Storage', value:Math.round(data.disk_percent)}
  ];
  const gaugesEl = document.getElementById('gauges');
  gaugesEl.innerHTML = '';
  const circ = 364.4;
  gaugeData.forEach(g => {
    const pct = g.max ? Math.min(g.value/g.max*100,100) : g.value;
    const dash = (pct/100)*circ;
    const suffix = g.suffix||'%';
    gaugesEl.innerHTML += `<div style="display:flex;flex-direction:column;align-items:center;gap:6px;"><div style="position:relative;width:145px;height:145px;"><svg width="145" height="145" viewBox="0 0 145 145"><circle cx="72" cy="72" r="58" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="8"/><circle cx="72" cy="72" r="58" fill="none" stroke="var(--accent)" stroke-width="8" stroke-dasharray="${dash} ${circ}" stroke-linecap="round" transform="rotate(-90 72 72)"/></svg><div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Orbitron',monospace;font-size:18px;color:var(--text);font-weight:700;">${g.value}${suffix}</div></div><div style="font-size:15px;color:var(--text-sub);font-weight:600;text-transform:uppercase;letter-spacing:1px;">${g.label}</div></div>`;
  });
}

async function fetchStats() {
  try {
    const res = await fetch('/api/system');
    const data = await res.json();
    buildGauges(data);
  } catch(e) {
    console.log('Stats fetch failed:', e);
  }
}

fetchEvents();
fetchStats();
setInterval(fetchEvents, 30000);
setInterval(fetchStats, 5000);
setInterval(fetchSolar, 3600000);

async function fetchSolar() {
  try {
    const r = await fetch('/api/solar');
    const d = await r.json();
    const el = document.getElementById('moon-phase');
    if (el) el.textContent = d.moon_icon + ' ' + d.moon_phase_name;
  } catch(e) {}
}
async function fetchSensors() {
  try {
    const r = await fetch('/api/sensors');
    const d = await r.json();
    if(d.sensors){
      d.sensors.forEach(s => {
        if(s.id==='rak_temp') document.getElementById('w-temp').textContent=s.last_value+'°F';
        if(s.id==='rak_humidity') document.getElementById('w-humid').textContent=s.last_value+'%';
        if(s.id==='rak_pressure') document.getElementById('w-pres').textContent=s.last_value+' hPa';
        if(s.id==='rak_airquality') document.getElementById('w-aqi').textContent=Math.round(s.last_value);
        if(s.id==='rak_dewpoint') document.getElementById('w-dewpoint').textContent=s.last_value+'°F';
      });
    }
  } catch(e) {}
}
fetchSensors();
setInterval(fetchSensors, 60000);
fetchSolar();

const canvas = document.getElementById('clock');
const ctx = canvas.getContext('2d');
const C = 660, R = C/2;

function _clockAccent(){
  if(typeof _themeColors!=='undefined'&&typeof _settings!=='undefined'){
    var c=_themeColors[_settings.activeTheme];
    if(c)return c.clock;
  }
  return '#1e5aff';
}
function _clockAccentDim(){
  if(typeof _themeColors!=='undefined'&&typeof _settings!=='undefined'){
    var c=_themeColors[_settings.activeTheme];
    if(c)return 'rgba('+c.rgb+',0.35)';
  }
  return 'rgba(30,90,255,0.35)';
}
function _clockText(){
  if(typeof _themeColors!=='undefined'&&typeof _settings!=='undefined'){
    var c=_themeColors[_settings.activeTheme];
    if(c)return c.text;
  }
  return '#e0e8ff';
}
function drawClock() {
  const now = new Date();
  const hrs = now.getHours(), mins = now.getMinutes(), secs = now.getSeconds();
  const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  ctx.clearRect(0,0,C,C);
  ctx.beginPath();
  ctx.arc(R,R,R-4,0,Math.PI*2);
  ctx.fillStyle='#0d0d0d';
  ctx.fill();
  for(let i=0;i<60;i++){
    const ang=(i*6-90)*Math.PI/180;
    const isMaj=i%5===0;
    const len=isMaj?28:14;
    const r1=R-22, r2=r1-len;
    ctx.beginPath();
    ctx.moveTo(R+r1*Math.cos(ang),R+r1*Math.sin(ang));
    ctx.lineTo(R+r2*Math.cos(ang),R+r2*Math.sin(ang));
    ctx.strokeStyle=isMaj?_clockAccent():_clockAccentDim();
    ctx.lineWidth=isMaj?4:2;
    ctx.stroke();
  }
  const nums=[
    {o:12,i:'00',a:0},{o:1,i:13,a:30},{o:2,i:14,a:60},{o:3,i:15,a:90},
    {o:4,i:16,a:120},{o:5,i:17,a:150},{o:6,i:18,a:180},{o:7,i:19,a:210},
    {o:8,i:20,a:240},{o:9,i:21,a:270},{o:10,i:22,a:300},{o:11,i:23,a:330}
  ];
  nums.forEach(n=>{
    const rad=(n.a-90)*Math.PI/180;
    ctx.font='bold 32px Orbitron';
    ctx.fillStyle=_clockText();
    ctx.textAlign='center';
    ctx.textBaseline='middle';
    ctx.fillText(n.o, R+242*Math.cos(rad), R+242*Math.sin(rad));
    ctx.font='400 18px Orbitron';
    ctx.fillStyle=_clockAccent();
    ctx.fillText(n.i, R+178*Math.cos(rad), R+178*Math.sin(rad));
  });
  const hourDeg=((hrs%12)*30+mins*0.5-90)*Math.PI/180;
  const minDeg=(mins*6+secs*0.1-90)*Math.PI/180;
  const secDeg=(secs*6-90)*Math.PI/180;
  ctx.lineCap='round';
  ctx.beginPath();
  ctx.moveTo(R,R);
  ctx.lineTo(R+162*Math.cos(hourDeg),R+162*Math.sin(hourDeg));
  ctx.strokeStyle=_clockAccent();
  ctx.lineWidth=10;
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(R,R);
  ctx.lineTo(R+220*Math.cos(minDeg),R+220*Math.sin(minDeg));
  ctx.strokeStyle=_clockAccent();
  ctx.lineWidth=6;
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(R,R);
  ctx.lineTo(R+248*Math.cos(secDeg),R+248*Math.sin(secDeg));
  ctx.strokeStyle='#ef4444';
  ctx.lineWidth=2.5;
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(R,R,14,0,Math.PI*2);
  ctx.fillStyle=_clockAccent();
  ctx.fill();
  const h24=String(hrs).padStart(2,'0');
  const m=String(mins).padStart(2,'0');
  const s=String(secs).padStart(2,'0');
  document.getElementById('timetext').textContent=`${h24}:${m}:${s}`;
  const mo=now.getMonth()+1, d=now.getDate(), y=now.getFullYear();
  document.getElementById('datetext').textContent=`${days[now.getDay()]} · ${mo}/${d}/${y}`;
  requestAnimationFrame(drawClock);
}
drawClock();
</script>

